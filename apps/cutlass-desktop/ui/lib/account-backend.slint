// Cutlass account plumbing, implemented in Rust (src/account.rs owns a
// worker thread; sign-in, balance, and update checks never touch the UI
// thread).
//
// Sign-in is the device-authorization flow through the system browser:
// the app shows a short code, the browser opens the website's approval
// page (provider choice happens there), and the app polls until the user
// approves. Tokens live in the OS keychain, never in a file. Credits are
// bought on the website's account page — the app never handles card data.

export global AccountBackend {
    // "signed-out" | "signing-in" | "signed-in".
    in-out property <string> status: "signed-out";
    in-out property <string> email: "";
    // OAuth provider of the account ("github" | "google").
    in-out property <string> provider: "";
    in-out property <string> error: "";

    // The short device-flow code to confirm in the browser; non-empty
    // only while status == "signing-in".
    in-out property <string> user-code: "";

    // Credit balance (managed path). `balance-known` gates the display so
    // a fetch failure shows "—" rather than a lying zero.
    in-out property <int> credits: 0;
    in-out property <bool> balance-known: false;

    // --- update nudge (launch screen) -----------------------------------
    in-out property <bool> update-available: false;
    in-out property <string> update-version: "";
    in-out property <string> update-url: "";

    // Start the device flow: opens the website's approval page in the
    // system browser and publishes `user-code` while polling.
    callback sign-in();
    // Revoke the session (server best-effort, keychain always).
    callback sign-out();
    // Re-fetch balance.
    callback refresh-balance();
    // Open the website's account page (balance, credit packs, receipts)
    // in the system browser.
    callback buy-credits();
    // Open the download page for an available update.
    callback open-update();
}
