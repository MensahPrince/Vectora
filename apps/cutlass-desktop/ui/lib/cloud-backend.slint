// Cloud plumbing for the Library's stock sections, implemented in Rust
// (src/cloud.rs owns a worker thread; network never touches the UI thread).
//
// Search results arrive as a published tile list; thumbnails stream in
// afterwards, patching rows in place (the thumbnail-registry pattern).
// Importing a tile downloads the media file directly from the provider's
// CDN into the quota-managed download cache, then routes it through the
// normal import path — an imported stock clip is ordinary pool media.

// One stock search result tile.
export struct StockTile {
    // Worker-side identity ("pexels:857191"); the UI hands back the row
    // index, the key guards against stale patches.
    key: string,
    thumbnail: image,
    has-thumbnail: bool,
    // Corner chip: duration for video ("0:12"), dimensions for photos.
    label: string,
    // "Video by X on Pexels" — shown in the tile tooltip/footer.
    attribution: string,
    // "" (idle) | "downloading" | "imported" | "failed".
    state: string,
    // 0..1 while downloading (0 when the size is unknown).
    progress: float,
}

export global CloudBackend {
    // --- stock search (Library > Media > Stock) -------------------------
    in-out property <string> stock-query: "";
    // "video" | "photo".
    in-out property <string> stock-kind: "video";
    in-out property <[StockTile]> stock-items: [];
    // "idle" (nothing searched yet) | "searching" | "results" | "empty"
    // | "error" — drives the section's empty/progress states.
    in-out property <string> stock-status: "idle";
    in-out property <string> stock-error: "";
    in-out property <bool> stock-has-more: false;
    in-out property <bool> stock-loading-more: false;

    // Run a fresh search with `stock-query` + `stock-kind` (Enter in the
    // search field or the kind toggle).
    callback stock-search();
    // Fetch the next page, appending to `stock-items`.
    callback stock-load-more();
    // Download row `index`'s best file and import it into the media pool.
    callback stock-import(index: int);
}
