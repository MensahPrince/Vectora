import { AppStore, EditorStore, TimelineStore, TimelineActions } from "../../store/index.slint";
import { Track, TrackKind } from "../../models/index.slint";
import { TimelineViewState } from "state.slint";
import { LineTextInput } from "../inspector/inspector-widgets.slint";

// One compact square toggle in a track header. `active` latches the accent
// when the lane is in its "special" state (hidden / muted / locked).
component HeadToggle inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();

    width: 18px;
    height: 18px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: active
        ? AppStore.theme.accent.primary.with-alpha(0.13)
        : ta.has-hover ? #ffffff1a : transparent;

    Text {
        width: 100%;
        height: 100%;
        text: label;
        font-size: 10px;
        horizontal-alignment: center;
        vertical-alignment: center;
        color: active ? AppStore.theme.accent.primary : AppStore.theme.text.secondary;
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component TrackMenuItem inherits Rectangle {
    in property <string> label;
    callback clicked();

    height: 28px;
    background: ta.has-hover ? #ffffff14 : transparent;

    Text {
        x: 8px;
        width: parent.width - 16px;
        height: parent.height;
        text: root.label;
        font-size: 12px;
        vertical-alignment: center;
        color: AppStore.theme.text.primary;
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

// Header for one lane: name plus the CapCut-style visibility/mute/lock
// toggles. The lane category decides which of the visual (eye) vs audio
// (speaker + voice tag) toggles show; lock applies to every lane.
export component TrackHead inherits Rectangle {
    in property <Track> track;
    in property <int> track-row: 0;
    in property <length> lane-height: AppStore.theme.track-lane.height;

    private property <int> track-count: EditorStore.project.sequence.tracks.length;

    // Stack index (0 = bottom) for insert/move helpers.
    private property <int> stack-index: max(0, track-count - 1 - track-row);

    width: 100%;
    height: lane-height;
    background: AppStore.theme.track-lane.background;
    opacity: TimelineViewState.track-drag-id == track.id ? 0.55 : 1.0;

    private property <string> rename-name: track.name;
    private property <length> drag-press-y: 0px;

    drag-ta := TouchArea {
        width: 100%;
        height: 100%;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                root.drag-press-y = self.mouse-y;
                TimelineViewState.track-drag-id = root.track.id;
                TimelineViewState.track-drag-source-row = root.track-row;
                TimelineViewState.track-drag-dy-px = 0px;
                TimelineViewState.track-drag-released = false;
            }
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.right) {
                menu-popup.show();
            }
            if (event.kind == PointerEventKind.up) {
                if (TimelineViewState.track-drag-id == root.track.id) {
                    TimelineViewState.track-drag-released = true;
                    TimelineActions.commit-track-reorder();
                }
            }
        }

        moved => {
            if (self.pressed && TimelineViewState.track-drag-id == root.track.id) {
                TimelineViewState.track-drag-dy-px = self.mouse-y - root.drag-press-y;
            }
        }
    }

    HorizontalLayout {
        padding-left: AppStore.theme.metrics.spacing.sm;
        padding-right: AppStore.theme.metrics.spacing.xs;
        padding-top: AppStore.theme.metrics.spacing.xs;
        padding-bottom: AppStore.theme.metrics.spacing.xs;
        spacing: 2px;

        Text {
            horizontal-stretch: 1;
            vertical-alignment: center;
            overflow: elide;
            text: root.track.name;
            font-size: 11px;
            color: root.track.enabled
                ? AppStore.theme.text.primary
                : AppStore.theme.text.secondary;
        }

        if root.track.kind != TrackKind.audio: HeadToggle {
            label: "V";
            active: !root.track.enabled;
            clicked => {
                EditorStore.on-track-flag-toggled(root.track.id, "enabled", !root.track.enabled);
            }
        }
        if root.track.kind == TrackKind.audio: HeadToggle {
            label: "M";
            active: root.track.muted;
            clicked => {
                EditorStore.on-track-flag-toggled(root.track.id, "muted", !root.track.muted);
            }
        }
        if root.track.kind == TrackKind.audio: HeadToggle {
            label: "V";
            active: root.track.duck-source;
            clicked => {
                EditorStore.on-track-flag-toggled(
                    root.track.id,
                    "duck-source",
                    !root.track.duck-source);
            }
        }

        HeadToggle {
            label: "L";
            active: root.track.locked;
            clicked => {
                EditorStore.on-track-flag-toggled(root.track.id, "locked", !root.track.locked);
            }
        }
    }

    menu-popup := PopupWindow {
        x: drag-ta.absolute-position.x + 8px;
        y: drag-ta.absolute-position.y + 8px;
        close-policy: PopupClosePolicy.close-on-click-outside;

        Rectangle {
            width: 180px;
            background: AppStore.theme.panel.background;
            border-radius: 4px;

            VerticalLayout {
                padding: 4px;
                spacing: 0;

                TrackMenuItem {
                    label: "Add video track above";
                    clicked => {
                        EditorStore.on-track-added("video", stack-index + 1, true);
                        menu-popup.close();
                    }
                }
                TrackMenuItem {
                    label: "Add video track below";
                    clicked => {
                        EditorStore.on-track-added("video", stack-index, true);
                        menu-popup.close();
                    }
                }
                TrackMenuItem {
                    label: "Add audio track above";
                    clicked => {
                        EditorStore.on-track-added("audio", stack-index + 1, true);
                        menu-popup.close();
                    }
                }
                TrackMenuItem {
                    label: "Add audio track below";
                    clicked => {
                        EditorStore.on-track-added("audio", stack-index, true);
                        menu-popup.close();
                    }
                }
                TrackMenuItem {
                    label: "Rename track…";
                    clicked => {
                        menu-popup.close();
                        rename-popup.show();
                    }
                }
                TrackMenuItem {
                    label: "Delete track";
                    clicked => {
                        EditorStore.on-track-removed(root.track.id);
                        menu-popup.close();
                    }
                }
            }
        }
    }

    rename-popup := PopupWindow {
        x: drag-ta.absolute-position.x + 8px;
        y: drag-ta.absolute-position.y + 8px;
        close-policy: PopupClosePolicy.close-on-click-outside;

        Rectangle {
            width: 200px;
            background: AppStore.theme.panel.background;
            border-radius: 4px;

            VerticalLayout {
                padding: 8px;
                spacing: 6px;

                LineTextInput {
                    text <=> rename-name;
                }

                Rectangle {
                    height: 28px;
                    background: AppStore.theme.accent.primary;
                    border-radius: 4px;
                    Text {
                        text: "Rename";
                        color: #ffffff;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        clicked => {
                            EditorStore.on-track-renamed(root.track.id, rename-name);
                            rename-popup.close();
                        }
                    }
                }
            }
        }
    }
}
