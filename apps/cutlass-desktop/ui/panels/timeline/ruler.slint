// CapCut-style timeline ruler.
//
// Visual layout (~30 px strip):
//
//   +----------------------------------------------------------------+
//   |  00:00  ·  ·  ·  ·  ·  ·  ·  00:01  ·  ·  ·  ▼  ·  ·  00:02   |
//   +-------------------------------------------|--------------------+
//                                          playhead pin
//
//   * Labels are centered on their position; CapCut draws no tick line
//     under them — the text is the marker.
//   * Subdivisions are small dots, not hash lines.
//   * The playhead is a white pin (rounded head + pointer) over a
//     hairline that continues down through the lanes (drawn there).
//
// Coordinate model:
//
//   This component lives inside a clipping `Rectangle` in
//   `timeline.slint` and stays put at x=0 within that container — it
//   does NOT translate with the scroll. It reads
//   `TimelineViewState.scroll-x` and passes it to the Rust backend,
//   which returns marks already positioned in *viewport-local* pixels
//   (`frame * zoom + scroll-x`). The playhead pin uses the same
//   projection; scrubbing converts viewport-local `mouse-x` back to
//   ticks via `(mouse-x - scroll-x) / zoom`.
//
// Scrubbing (CapCut behaviour):
//
//   Press or drag anywhere on the strip to move the playhead. While
//   the Snap magnet is on, the playhead magnets to clip edges and
//   tick 0 — same candidates and threshold as clip drags, through the
//   same Rust resolver (`DragBackend.snap-clip-start` with a zero-width
//   "clip").

import { AppStore, TimelineStore, EditorStore, TimelineActions } from "../../store/index.slint";
import { CutlassText } from "../../components/index.slint";
import { TimelineViewState } from "state.slint";
import { RulerBackend, RulerTick } from "../../lib/ruler-backend.slint";
import { DragBackend } from "../../lib/drag-backend.slint";
import { AppState } from "../../state.slint";
import { LineTextInput } from "../inspector/inspector-widgets.slint";

component MarkerColorSwatch inherits Rectangle {
    in property <string> color-name;
    in property <color> swatch-color;
    in property <bool> selected;
    callback picked();

    width: 18px;
    height: 18px;
    border-radius: 3px;
    background: swatch-color;
    border-width: selected ? 2px : 0px;
    border-color: #ffffff;

    ta := TouchArea {
        clicked => {
            root.picked();
        }
    }
}

export component Ruler inherits Rectangle {
    private property <length> scroll-x: TimelineViewState.scroll-x;
    private property <float> zoom: TimelineStore.zoom;
    private property <int> fps-num: EditorStore.project.sequence.fps.num;
    private property <int> fps-den: EditorStore.project.sequence.fps.den;

    private property <[RulerTick]> tick-model:
        RulerBackend.ticks(scroll-x, self.width, zoom, fps-num, fps-den);

    private property <length> playhead-x:
        TimelineStore.playhead-tick * zoom * 1px + scroll-x;

    // CapCut's magnet: ~10 px of pull at the current zoom; 0 ⇔ off.
    private property <int> snap-threshold-ticks:
        TimelineStore.snap-enabled ? max(1, round(10 / zoom)) : 0;

    // Marker drag / editor state.
    private property <string> marker-drag-id: "";
    private property <int> marker-drag-tick: -1;
    private property <bool> marker-drag-active: false;
    private property <string> marker-edit-id: "";
    private property <int> marker-edit-tick: 0;
    private property <string> marker-edit-name: "";
    private property <string> marker-edit-color: "teal";

    function snap-tick(raw-tick: int) -> int {
        return DragBackend.snap-clip-start(
            EditorStore.project.sequence,
            "",
            "",
            raw-tick,
            0,
            snap-threshold-ticks,
            0).snapped-start-value;
    }

    // Move the playhead to the frame under viewport-local `mx`,
    // magneting to clip edges / tick 0 when the snap toggle is on.
    function scrub-to(mx: length) {
        TimelineStore.playhead-tick = TimelineActions.clamp-playhead(
            self.snap-tick(max(0, round((mx - scroll-x) / 1px / zoom))));
    }

    private property <length> range-in-x:
        TimelineStore.range-in-tick * zoom * 1px + scroll-x;
    private property <length> range-out-x:
        TimelineStore.range-out-tick * zoom * 1px + scroll-x;

    if TimelineStore.range-in-tick >= 0
        && TimelineStore.range-out-tick > TimelineStore.range-in-tick: Rectangle {
        x: range-in-x;
        y: 0;
        width: range-out-x - range-in-x;
        height: parent.height;
        background: AppStore.theme.accent.primary.with-alpha(0.1);
    }

    if TimelineStore.range-in-tick >= 0: Rectangle {
        x: range-in-x;
        y: 0;
        width: 2px;
        height: parent.height;
        background: AppStore.theme.accent.primary;
    }

    if TimelineStore.range-out-tick >= 0: Rectangle {
        x: range-out-x - 2px;
        y: 0;
        width: 2px;
        height: parent.height;
        background: AppStore.theme.accent.primary;
    }

    for tick in tick-model: Rectangle {
        x: tick.x;
        y: 0;
        width: 0;
        height: parent.height;

        if !tick.is-major: Rectangle {
            x: -1px;
            y: parent.height / 2 - 1px;
            width: 2px;
            height: 2px;
            border-radius: 1px;
            background: AppStore.theme.text.muted;
        }

        if tick.is-major: CutlassText {
            x: -self.width / 2;
            y: parent.height / 2 - self.height / 2;
            text: tick.label;
            mono: true;
            style: AppStore.theme.typography.caption;
            foreground: AppStore.theme.text.secondary;
        }
    }

    scrub := TouchArea {
        width: parent.width;
        height: parent.height;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                AppState.refocus-shortcuts();
                root.scrub-to(self.mouse-x);
            }
        }

        moved => {
            if self.pressed {
                root.scrub-to(self.mouse-x);
            }
        }
    }

    // Ghost flag while dragging a marker.
    if marker-drag-active: Rectangle {
        x: marker-drag-tick * zoom * 1px + scroll-x;
        y: 0;
        width: 0;
        height: parent.height;

        Rectangle {
            x: -3px;
            y: 2px;
            width: 6px;
            height: 10px;
            border-radius: 1px;
            background: AppStore.theme.accent.primary;
            opacity: 0.75;
        }
    }

    for marker in EditorStore.project.sequence.markers: Rectangle {
        property <length> marker-x: marker.tick * zoom * 1px + scroll-x;
        x: marker-x;
        y: 0;
        width: 0;
        height: parent.height;
        visible: marker-drag-active ? marker.id != marker-drag-id : true;

        Rectangle {
            x: -3px;
            y: 2px;
            width: 6px;
            height: 10px;
            border-radius: 1px;
            background: marker.color;
        }

        if marker.name != "": CutlassText {
            x: 5px;
            y: 1px;
            text: marker.name;
            style: AppStore.theme.typography.caption;
            foreground: marker.color;
        }

        marker-ta := TouchArea {
            x: -8px;
            y: 0;
            width: 16px;
            height: parent.height;
            mouse-cursor: MouseCursor.pointer;

            property <length> press-x: 0px;
            property <bool> moved-since-press: false;

            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    AppState.refocus-shortcuts();
                    self.press-x = self.mouse-x;
                    self.moved-since-press = false;
                    if (e.button == PointerEventButton.right) {
                        TimelineActions.remove-marker(marker.id);
                    } else if (e.button == PointerEventButton.left) {
                        root.marker-drag-id = marker.id;
                        root.marker-drag-tick = marker.tick;
                        root.marker-drag-active = false;
                    }
                }
                if (e.kind == PointerEventKind.up && e.button == PointerEventButton.left) {
                    if (root.marker-drag-active) {
                        TimelineActions.set-marker(
                            marker.id,
                            root.marker-drag-tick,
                            marker.name,
                            marker.color-name);
                        root.marker-drag-id = "";
                        root.marker-drag-active = false;
                    } else if (!self.moved-since-press) {
                        TimelineStore.playhead-tick =
                            TimelineActions.clamp-playhead(marker.tick);
                    }
                }
            }

            moved => {
                if (!self.pressed || root.marker-drag-id != marker.id) {
                    return;
                }
                if (abs((self.mouse-x - self.press-x) / 1px) > 3) {
                    self.moved-since-press = true;
                    root.marker-drag-active = true;
                }
                if (root.marker-drag-active) {
                    root.marker-drag-tick = root.snap-tick(max(0, round(
                        (self.mouse-x - scroll-x) / 1px / zoom)));
                }
            }

            double-clicked => {
                root.marker-edit-id = marker.id;
                root.marker-edit-tick = marker.tick;
                root.marker-edit-name = marker.name;
                root.marker-edit-color = marker.color-name;
                marker-editor.show();
            }
        }
    }

    marker-editor := PopupWindow {
        x: playhead-x;
        y: parent.height + 4px;
        close-policy: PopupClosePolicy.close-on-click-outside;

        Rectangle {
            width: 220px;
            background: AppStore.theme.panel.background;
            border-radius: 4px;

            VerticalLayout {
            padding: 8px;
            spacing: 6px;

            CutlassText {
                text: "Marker";
                style: AppStore.theme.typography.label;
            }

            LineTextInput {
                text <=> marker-edit-name;
            }

            HorizontalLayout {
                spacing: 4px;
                MarkerColorSwatch {
                    color-name: "teal";
                    swatch-color: #3DB8A8;
                    selected: marker-edit-color == "teal";
                    picked => { marker-edit-color = "teal"; }
                }
                MarkerColorSwatch {
                    color-name: "blue";
                    swatch-color: #4A7FD4;
                    selected: marker-edit-color == "blue";
                    picked => { marker-edit-color = "blue"; }
                }
                MarkerColorSwatch {
                    color-name: "purple";
                    swatch-color: #8B5FD4;
                    selected: marker-edit-color == "purple";
                    picked => { marker-edit-color = "purple"; }
                }
                MarkerColorSwatch {
                    color-name: "pink";
                    swatch-color: #D45FA0;
                    selected: marker-edit-color == "pink";
                    picked => { marker-edit-color = "pink"; }
                }
                MarkerColorSwatch {
                    color-name: "red";
                    swatch-color: #D44A4A;
                    selected: marker-edit-color == "red";
                    picked => { marker-edit-color = "red"; }
                }
                MarkerColorSwatch {
                    color-name: "orange";
                    swatch-color: #D48A3A;
                    selected: marker-edit-color == "orange";
                    picked => { marker-edit-color = "orange"; }
                }
                MarkerColorSwatch {
                    color-name: "yellow";
                    swatch-color: #D4B83A;
                    selected: marker-edit-color == "yellow";
                    picked => { marker-edit-color = "yellow"; }
                }
                MarkerColorSwatch {
                    color-name: "green";
                    swatch-color: #4AB85A;
                    selected: marker-edit-color == "green";
                    picked => { marker-edit-color = "green"; }
                }
            }

            Rectangle {
                height: 28px;
                background: AppStore.theme.accent.primary;
                border-radius: 4px;
                Text {
                    text: "Apply";
                    color: #ffffff;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea {
                    clicked => {
                        if (marker-edit-id != "") {
                            TimelineActions.set-marker(
                                marker-edit-id,
                                marker-edit-tick,
                                marker-edit-name,
                                marker-edit-color);
                        }
                        marker-editor.close();
                    }
                }
            }
        }
        }
    }

    Rectangle {
        x: playhead-x;
        y: 0;
        width: 1px;
        height: parent.height;
        background: AppStore.theme.text.primary;
    }

    Rectangle {
        x: playhead-x - 4.5px;
        y: 3px;
        width: 10px;
        height: 10px;
        border-radius: 3px;
        background: AppStore.theme.text.primary;
    }

    Path {
        x: playhead-x - 4.5px;
        y: 12px;
        width: 10px;
        height: 5px;
        viewbox-width: 10;
        viewbox-height: 5;
        commands: "M 0 0 L 10 0 L 5 5 Z";
        fill: AppStore.theme.text.primary;
    }
}
