// Clip-level look animations (CapCut In / Out / Combo tabs). Values are
// projected from the engine; picks route to undoable SetClipAnimation edits.

import { CutlassScrollView, CutlassText } from "../../components/index.slint";
import { AppState } from "../../state.slint";
import { AppStore } from "../../store/index.slint";
import { InspectorBackend } from "../../lib/inspector-backend.slint";
import { Clip, CatalogEntry } from "../../models/index.slint";
import { LabelCell, SectionHeader } from "inspector-widgets.slint";

component AnimationPresetRow inherits Rectangle {
    in property <string> label;
    in property <string> id;
    in property <bool> selected;
    callback picked(id: string);

    height: 26px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: root.selected
        ? AppStore.theme.accent.primary.with-alpha(0.12)
        : (ta.has-hover ? #ffffff10 : transparent);

    CutlassText {
        x: AppStore.theme.metrics.spacing.sm;
        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
        height: parent.height;
        vertical-alignment: center;
        text: root.label;
        style: AppStore.theme.typography.body;
        foreground: root.selected ? AppStore.theme.accent.primary : AppStore.theme.text.primary;
        overflow: TextOverflow.elide;
    }

    ta := TouchArea {
        clicked => {
            root.picked(root.id);
            AppState.refocus-shortcuts();
        }
    }
}

component AnimationDropdown inherits Rectangle {
    in property <string> current-id;
    in property <string> current-label;
    in property <[CatalogEntry]> catalog;

    callback selected(id: string);

    height: 28px;
    horizontal-stretch: 1;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: trigger.has-hover ? #232323 : #1a1a1a;

    HorizontalLayout {
        padding-left: AppStore.theme.metrics.spacing.sm;
        padding-right: AppStore.theme.metrics.spacing.sm;
        spacing: AppStore.theme.metrics.spacing.xs;

        CutlassText {
            horizontal-stretch: 1;
            vertical-alignment: center;
            text: root.current-id == "" ? "None" : root.current-label;
            style: AppStore.theme.typography.body;
            foreground: root.current-id == "" ? AppStore.theme.text.muted : AppStore.theme.text.primary;
            overflow: TextOverflow.elide;
        }

        CutlassText {
            width: 12px;
            vertical-alignment: center;
            horizontal-alignment: center;
            text: "v";
            style: AppStore.theme.typography.caption;
            foreground: AppStore.theme.text.muted;
        }
    }

    trigger := TouchArea {
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        x: 0;
        y: root.height + 4px;
        width: root.width;
        height: 220px;
        close-policy: PopupClosePolicy.close-on-click-outside;

        Rectangle {
            width: 100%;
            height: 100%;
            background: AppStore.theme.panel.background;
            border-radius: AppStore.theme.metrics.radius.md;
            border-width: 1px;
            border-color: #ffffff1f;
            drop-shadow-blur: 24px;
            drop-shadow-color: #00000080;
            drop-shadow-offset-y: 6px;

            VerticalLayout {
                padding: AppStore.theme.metrics.spacing.sm;
                spacing: 0;

                CutlassScrollView {
                    vertical-stretch: 1;
                    viewport-width: self.width;
                    viewport-height: list.preferred-height;
                    show-horizontal-scrollbar: false;

                    list := VerticalLayout {
                        spacing: 0;
                        alignment: LayoutAlignment.start;

                        AnimationPresetRow {
                            label: "None";
                            id: "";
                            selected: root.current-id == "";
                            picked(id) => {
                                root.selected(id);
                                popup.close();
                            }
                        }

                        for entry in root.catalog: AnimationPresetRow {
                            label: entry.label;
                            id: entry.id;
                            selected: entry.id == root.current-id;
                            picked(id) => {
                                root.selected(id);
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

export component AnimationInspector inherits VerticalLayout {
    in property <Clip> model;
    in property <bool> text-only-combos: false;

    spacing: AppStore.theme.metrics.spacing.lg;
    alignment: LayoutAlignment.start;

    SectionHeader {
        title: "Entrance";
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.md;
        height: 28px;
        vertical-stretch: 0;

        LabelCell {
            label: "In";
        }

        AnimationDropdown {
            current-id: root.model.animation-in-id;
            current-label: root.model.animation-in-label;
            catalog: InspectorBackend.animation-in-catalog;
            selected(id) => {
                InspectorBackend.set-clip-animation(root.model.id, "in", id);
            }
        }
    }

    SectionHeader {
        title: "Exit";
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.md;
        height: 28px;
        vertical-stretch: 0;

        LabelCell {
            label: "Out";
        }

        AnimationDropdown {
            current-id: root.model.animation-out-id;
            current-label: root.model.animation-out-label;
            catalog: InspectorBackend.animation-out-catalog;
            selected(id) => {
                InspectorBackend.set-clip-animation(root.model.id, "out", id);
            }
        }
    }

    SectionHeader {
        title: "Combo";
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.md;
        height: 28px;
        vertical-stretch: 0;

        LabelCell {
            label: "Loop";
        }

        AnimationDropdown {
            current-id: root.model.animation-combo-id;
            current-label: root.model.animation-combo-label;
            catalog: root.text-only-combos
                ? InspectorBackend.animation-text-combo-catalog
                : InspectorBackend.animation-combo-catalog;
            selected(id) => {
                InspectorBackend.set-clip-animation(root.model.id, "combo", id);
            }
        }
    }
}
