// Draggable library tiles. Both kinds feed the same library-drag state
// machine (window ghost + timeline landing ghost, see AppState): the payload
// is either a media-pool id (`MediaTile`) or a generator catalog key
// (`GeneratedTile`); release over the timeline fires the matching
// EditorStore drop callback.

import { CutlassText } from "../../components/index.slint";
import { AppStore, EditorStore, TimelineStore } from "../../store/index.slint";
import { EffectsBackend } from "../../lib/effects-backend.slint";
import { CloudBackend, StockTile } from "../../lib/cloud-backend.slint";
import { SfxBackend, SfxTile } from "../../lib/sfx-backend.slint";
import { TextPresetTile } from "../../lib/text-presets-backend.slint";
import { AiBackend, AiItemTile } from "../../lib/ai-backend.slint";
import { AppState } from "../../state.slint";
import { Media, TrackKind } from "../../models/index.slint";

// One effect/transition catalog tile (M4). A click applies to the current
// timeline selection (effects → the selected clip's chain), so `enabled`
// reflects whether a click target exists. Tiles with a `generator` drag key
// also feed the library-drag state machine: dropping on the timeline lands a
// standalone effect segment on an effect lane (CapCut's effect-as-track-clip),
// no selection needed. A gradient swatch keeps the grid lively without
// per-effect art.
export component CatalogTile inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    in property <color> swatch: #3A6FC8;
    // Library-drag payload ("effect:<id>"); empty disables dragging.
    in property <string> generator;
    // Lane kind a dragged tile lands on.
    in property <TrackKind> lane-kind: TrackKind.effect;
    // Default placement length in seconds for dragged segments.
    in property <int> seconds: 3;
    callback apply();

    property <int> fps-num: EditorStore.project.sequence.fps.num;
    property <int> fps-den: EditorStore.project.sequence.fps.den;

    background: AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;
    // Draggable tiles stay fully lit even without a click target.
    opacity: root.enabled || root.generator != "" ? 1.0 : 0.45;

    Rectangle {
        width: parent.width - 16px;
        height: parent.height - 16px - 22px;
        y: 8px;
        x: 8px;
        border-radius: 4px;
        background: @linear-gradient(135deg, root.swatch 0%, root.swatch.darker(0.4) 100%);

        CutlassText {
            text: "fx";
            style: { size: 16px, weight: 600, italic: false };
            foreground: #ffffffcc;
        }
    }

    VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #000000a0;
            CutlassText {
                text: root.label;
                style: AppStore.theme.typography.label;
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }

    if root.enabled || root.generator != "": TouchArea {
        pointer-event(event) => {
            if root.generator != "" && event.kind == PointerEventKind.down
                && event.button == PointerEventButton.left {
                AppState.library-drag-media-id = "";
                AppState.library-drag-generator = root.generator;
                AppState.library-drag-lane-kind = root.lane-kind;
                AppState.library-drag-duration-ticks =
                    max(1, round(root.seconds * root.fps-num / root.fps-den));
                AppState.library-drag-w = root.width;
                AppState.library-drag-h = root.height;
                AppState.library-drag-tile-anchor-x = self.mouse-x;
                AppState.library-drag-tile-anchor-y = self.mouse-y;
                AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
                AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
                AppState.library-drag-active = true;
            }
            if event.kind == PointerEventKind.up {
                AppState.library-drag-active = false;
            }
            if event.kind == PointerEventKind.cancel {
                // Move cursor off-window so the timeline drop handler won't
                // commit if the grab was stolen mid-drag.
                AppState.library-drag-cursor-x = -10000px;
                AppState.library-drag-cursor-y = -10000px;
                AppState.library-drag-active = false;
            }
        }

        moved => {
            if !self.pressed || !AppState.library-drag-active {
                return;
            }
            AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
            AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
        }

        clicked => {
            if root.enabled {
                root.apply();
            }
        }
    }
}

// Draggable transition catalog tile — drops onto clip junctions on the timeline.
export component TransitionCatalogTile inherits Rectangle {
    in property <string> transition-id;
    in property <string> label;
    in property <color> swatch: #C84A8F;

    background: AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;

    Rectangle {
        width: parent.width - 16px;
        height: parent.height - 16px - 22px;
        y: 8px;
        x: 8px;
        border-radius: 4px;
        background: @linear-gradient(135deg, root.swatch 0%, root.swatch.darker(0.4) 100%);

        CutlassText {
            text: "tr";
            style: { size: 16px, weight: 600, italic: false };
            foreground: #ffffffcc;
        }
    }

    VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #000000a0;
            CutlassText {
                text: root.label;
                style: AppStore.theme.typography.label;
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }

    TouchArea {
        width: 100%;
        height: 100%;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                AppState.transition-drag-id = transition-id;
                AppState.transition-drag-w = root.width;
                AppState.transition-drag-h = root.height;
                AppState.transition-drag-tile-anchor-x = self.mouse-x;
                AppState.transition-drag-tile-anchor-y = self.mouse-y;
                AppState.transition-drag-cursor-x = self.absolute-position.x + self.mouse-x;
                AppState.transition-drag-cursor-y = self.absolute-position.y + self.mouse-y;
                AppState.transition-drag-active = true;
            }
            if event.kind == PointerEventKind.up {
                AppState.transition-drag-active = false;
            }
            if event.kind == PointerEventKind.cancel {
                AppState.transition-drag-cursor-x = -10000px;
                AppState.transition-drag-cursor-y = -10000px;
                AppState.transition-drag-active = false;
            }
        }

        moved => {
            if !self.pressed || !AppState.transition-drag-active {
                return;
            }
            AppState.transition-drag-cursor-x = self.absolute-position.x + self.mouse-x;
            AppState.transition-drag-cursor-y = self.absolute-position.y + self.mouse-y;
        }

        clicked => {
            if (TimelineStore.selected-clip-id != "") {
                EffectsBackend.add-transition(TimelineStore.selected-clip-id, transition-id);
            }
        }
    }
}

// One imported source from the media pool: poster frame / waveform card,
// duration badge, name strip. Dragging targets a video lane — or an audio
// lane for audio-only media, so the landing ghost tracks lanes the worker
// would actually place the clip on.
export component MediaTile inherits Rectangle {
    in property <Media> media;

    // Lazy-content gate, bound by grid call sites to the grid's
    // visible-index range so offscreen tiles skip the thumbnail
    // element (and its texture) entirely. Chrome stays unconditional.
    in property <bool> thumbnail-visible: true;

    // Audio tiles show the waveform card color while the waveform image is
    // still rendering; video tiles stay dark until the poster frame lands.
    background: media.is-audio ? #2A46C8 : AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;

    // Cursor position (tile-local) of the last right-press, used to anchor the
    // context-menu popup below.
    property <length> menu-x;
    property <length> menu-y;

    // Poster frame (video) or waveform card (audio), generated off-thread
    // after import — empty until ready (see src/thumbnails.rs).
    if thumbnail-visible && media.thumbnail.width > 0: Image {
        width: parent.width;
        height: parent.height;
        source: media.thumbnail;
        image-fit: cover;
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                AppState.library-drag-media-id = media.id;
                AppState.library-drag-generator = "";
                AppState.library-drag-lane-kind = media.is-audio
                    ? TrackKind.audio
                    : TrackKind.video;
                AppState.library-drag-duration-ticks = media.duration-ticks;
                AppState.library-drag-w = root.width;
                AppState.library-drag-h = root.height;
                AppState.library-drag-tile-anchor-x = self.mouse-x;
                AppState.library-drag-tile-anchor-y = self.mouse-y;
                AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
                AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
                AppState.library-drag-active = true;
            }
            // Right-press opens the tile's context menu at the cursor.
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.right {
                root.menu-x = self.mouse-x;
                root.menu-y = self.mouse-y;
                menu-popup.show();
            }
            if event.kind == PointerEventKind.up {
                AppState.library-drag-active = false;
            }
            if event.kind == PointerEventKind.cancel {
                AppState.library-drag-cursor-x = -10000px;
                AppState.library-drag-cursor-y = -10000px;
                AppState.library-drag-active = false;
            }
        }

        moved => {
            if !self.pressed || !AppState.library-drag-active {
                return;
            }
            AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
            AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
        }
    }

    // Duration badge, top-right like CapCut. Stills badge their kind
    // instead: the 5s pool duration is a default placement length, not a
    // property of the file.
    Rectangle {
        x: parent.width - self.width - 4px;
        y: 4px;
        width: duration-text.preferred-width + 8px;
        height: duration-text.preferred-height + 4px;
        background: #000000a0;
        border-radius: 3px;
        visible: media.is-image || media.duration-label != "";

        duration-text := CutlassText {
            x: 4px;
            y: 2px;
            text: media.is-image ? "IMG" : media.duration-label;
            style: AppStore.theme.typography.label;
        }
    }

    // Name label strip along the bottom of the tile.
    VerticalLayout {
        alignment: end;

        Rectangle {
            height: 22px;
            background: #000000a0;

            CutlassText {
                text: media.name;
                style: AppStore.theme.typography.label;
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
            }
        }
    }

    // Missing badge (v1 roadmap M0): the source file is gone — clips stay
    // but can't decode. Clicking the badge opens the relink picker, the
    // same flow as the relink dialog's "Locate…" (worker re-probes, swaps
    // the path, republishes; the badge clears with the next projection).
    if media.is-missing: Rectangle {
        x: 4px;
        y: 4px;
        width: missing-text.preferred-width + 8px;
        height: missing-text.preferred-height + 4px;
        background: #C83A3AE0;
        border-radius: 3px;

        missing-text := CutlassText {
            x: 4px;
            y: 2px;
            text: "Missing";
            style: AppStore.theme.typography.label;
        }

        TouchArea {
            clicked => {
                EditorStore.on-relink-media-requested(media.id);
            }
        }
    }

    // Right-click "Remove from project" menu, anchored at the press point.
    // A plain PopupWindow (close-on-click-outside) rather than a
    // ContextMenuArea: the area's native right-click gesture was swallowed by
    // the drag TouchArea above, and a programmatic show() left a stale active
    // menu that re-opened on the next right-click anywhere. This popup is fully
    // local — it dismisses on any outside click and never re-triggers itself.
    // Routing: an unused source deletes straight away; a used one raises the
    // confirm dialog, which cascades the referencing clips' removal in one undo.
    menu-popup := PopupWindow {
        x: root.menu-x;
        y: root.menu-y;
        close-policy: PopupClosePolicy.close-on-click-outside;

        Rectangle {
            width: 184px;
            height: menu-list.preferred-height;
            background: AppStore.theme.panel.background;
            border-radius: AppStore.theme.metrics.radius.md;
            border-width: 1px;
            border-color: #ffffff1f;
            drop-shadow-blur: 24px;
            drop-shadow-color: #00000080;
            drop-shadow-offset-y: 6px;

            menu-list := VerticalLayout {
                padding: AppStore.theme.metrics.spacing.xs;
                spacing: 0;

                Rectangle {
                    height: 28px;
                    border-radius: AppStore.theme.metrics.radius.sm;
                    background: remove-ta.has-hover ? #ffffff10 : transparent;

                    CutlassText {
                        x: AppStore.theme.metrics.spacing.sm;
                        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
                        height: parent.height;
                        vertical-alignment: center;
                        text: "Remove from project";
                        style: AppStore.theme.typography.body;
                        foreground: AppStore.theme.text.primary;
                        overflow: elide;
                    }

                    remove-ta := TouchArea {
                        clicked => {
                            // Reclaim focus so the next Delete/etc. acts on the
                            // timeline, not a stale text box.
                            AppState.refocus-shortcuts();
                            if (root.media.usage-count > 0) {
                                AppState.confirm-delete-media-id = root.media.id;
                                AppState.confirm-delete-media-name = root.media.name;
                                AppState.confirm-delete-media-clip-count = root.media.usage-count;
                                AppState.confirm-delete-media-open = true;
                            } else {
                                EditorStore.on-media-deleted(root.media.id, false);
                            }
                            menu-popup.close();
                        }
                    }
                }
            }
        }
    }
}

// One draggable generator tile (text title, solid, shape). The payload
// carries a generator catalog key instead of a media id, and the commit
// fires EditorStore.on-generated-dropped.
export component GeneratedTile inherits Rectangle {
    // Catalog key: "text" | "solid" | "rect" | "ellipse" | "sticker:<id>".
    in property <string> generator;
    in property <string> label;
    // Lane kind this generator lives on (text titles → text, the rest → sticker).
    in property <TrackKind> lane-kind;
    // Default placement length in seconds (text 3s, solids/shapes/stickers 5s).
    in property <int> seconds;
    // Preview swatch fill.
    in property <color> swatch;
    // Draw the swatch as an ellipse rather than a rectangle.
    in property <bool> round-swatch: false;
    // Sticker art thumbnail; when set it replaces the color swatch.
    in property <image> icon;

    property <int> fps-num: EditorStore.project.sequence.fps.num;
    property <int> fps-den: EditorStore.project.sequence.fps.den;

    background: AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;

    if root.icon.width == 0: Rectangle {
        width: 44px;
        height: 44px;
        y: (parent.height - 22px - self.height) / 2;
        background: root.swatch;
        border-radius: root.round-swatch ? self.width / 2 : 4px;
    }

    if root.icon.width > 0: Image {
        width: 52px;
        height: 52px;
        y: (parent.height - 22px - self.height) / 2;
        source: root.icon;
        image-fit: contain;
    }

    VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #000000a0;
            CutlassText {
                text: root.label;
                style: AppStore.theme.typography.label;
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                AppState.library-drag-media-id = "";
                AppState.library-drag-generator = root.generator;
                AppState.library-drag-lane-kind = root.lane-kind;
                AppState.library-drag-duration-ticks =
                    max(1, round(root.seconds * root.fps-num / root.fps-den));
                AppState.library-drag-w = root.width;
                AppState.library-drag-h = root.height;
                AppState.library-drag-tile-anchor-x = self.mouse-x;
                AppState.library-drag-tile-anchor-y = self.mouse-y;
                AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
                AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
                AppState.library-drag-active = true;
            }
            if event.kind == PointerEventKind.up {
                AppState.library-drag-active = false;
            }
            if event.kind == PointerEventKind.cancel {
                AppState.library-drag-cursor-x = -10000px;
                AppState.library-drag-cursor-y = -10000px;
                AppState.library-drag-active = false;
            }
        }

        moved => {
            if !self.pressed || !AppState.library-drag-active {
                return;
            }
            AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
            AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
        }
    }
}

// One stock search result: thumbnail card, corner label chip (duration /
// dimensions), attribution strip, and a click-to-import flow with inline
// download progress. Stock tiles are not draggable — the file isn't local
// until imported, at which point it appears under Local as normal pool
// media (and gets the usual draggable MediaTile).
export component StockMediaTile inherits Rectangle {
    in property <StockTile> tile;
    in property <int> index;

    // Lazy-content gate, bound by grid call sites to the grid's
    // visible-index range so offscreen tiles skip the thumbnail
    // element (and its texture) entirely. Chrome stays unconditional.
    in property <bool> thumbnail-visible: true;

    background: AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;

    if thumbnail-visible && tile.has-thumbnail: Image {
        width: parent.width;
        height: parent.height;
        source: tile.thumbnail;
        image-fit: cover;
    }

    // Corner chip: duration / dimensions.
    if tile.label != "": Rectangle {
        x: 4px;
        y: 4px;
        width: chip.preferred-width + 8px;
        height: 16px;
        border-radius: 3px;
        background: #000000a0;

        chip := CutlassText {
            text: tile.label;
            style: { size: 10px, weight: 500, italic: false };
            foreground: #ffffffcc;
        }
    }

    // Attribution strip (Pexels/Pixabay goodwill credit), hover-revealed.
    if ta.has-hover && tile.attribution != "": VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #000000a0;
            CutlassText {
                text: tile.attribution;
                style: { size: 10px, weight: 400, italic: false };
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
            }
        }
    }

    // Download state overlay.
    if tile.state == "downloading": Rectangle {
        background: #00000080;

        VerticalLayout {
            alignment: center;
            padding: 12px;
            spacing: 6px;

            CutlassText {
                text: "Downloading…";
                style: AppStore.theme.typography.caption;
                horizontal-alignment: center;
            }

            Rectangle {
                height: 3px;
                border-radius: 1.5px;
                background: #ffffff22;

                Rectangle {
                    x: 0;
                    width: parent.width * max(0.05, tile.progress);
                    height: parent.height;
                    border-radius: parent.border-radius;
                    background: AppStore.theme.accent.primary;
                }
            }
        }
    }

    if tile.state == "imported": Rectangle {
        x: parent.width - self.width - 4px;
        y: 4px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        background: AppStore.theme.accent.primary;

        CutlassText {
            text: "✓";
            style: { size: 11px, weight: 700, italic: false };
            foreground: #ffffff;
        }
    }

    if tile.state == "failed": VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #7a1f1fd0;
            CutlassText {
                text: "Download failed — click to retry";
                style: { size: 10px, weight: 500, italic: false };
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
            }
        }
    }

    ta := TouchArea {
        clicked => {
            if tile.state != "downloading" && tile.state != "imported" {
                CloudBackend.stock-import(root.index);
            }
        }
    }
}

// One catalog sound effect (Library > Audio > Sound effects): name over an
// audio glyph stage, duration chip, provenance strip on hover, and the
// stock click-to-import flow with inline download progress. Like stock,
// SFX tiles are not draggable — importing lands the file in the pool under
// Audio > Local as a normal draggable MediaTile.
export component SfxAudioTile inherits Rectangle {
    in property <SfxTile> tile;
    in property <int> index;

    background: AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;

    CutlassText {
        width: parent.width;
        height: parent.height - 22px;
        text: "♪";
        horizontal-alignment: center;
        vertical-alignment: center;
        style: { size: 22px, weight: 400, italic: false };
        foreground: AppStore.theme.text.muted;
    }

    // Corner chip: duration.
    if tile.duration-label != "": Rectangle {
        x: 4px;
        y: 4px;
        width: sfx-chip.preferred-width + 8px;
        height: 16px;
        border-radius: 3px;
        background: #000000a0;

        sfx-chip := CutlassText {
            text: tile.duration-label;
            style: { size: 10px, weight: 500, italic: false };
            foreground: #ffffffcc;
        }
    }

    // Name strip; hover swaps in the provenance credit.
    VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #000000a0;
            CutlassText {
                text: ta.has-hover && tile.attribution != "" ? tile.attribution : tile.name;
                style: { size: 10px, weight: 500, italic: false };
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
            }
        }
    }

    // Download state overlay.
    if tile.state == "downloading": Rectangle {
        background: #00000080;

        VerticalLayout {
            alignment: center;
            padding: 12px;
            spacing: 6px;

            CutlassText {
                text: "Downloading…";
                style: AppStore.theme.typography.caption;
                horizontal-alignment: center;
            }

            Rectangle {
                height: 3px;
                border-radius: 1.5px;
                background: #ffffff22;

                Rectangle {
                    x: 0;
                    width: parent.width * max(0.05, tile.progress);
                    height: parent.height;
                    border-radius: parent.border-radius;
                    background: AppStore.theme.accent.primary;
                }
            }
        }
    }

    if tile.state == "imported": Rectangle {
        x: parent.width - self.width - 4px;
        y: 4px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        background: AppStore.theme.accent.primary;

        CutlassText {
            text: "✓";
            style: { size: 11px, weight: 700, italic: false };
            foreground: #ffffff;
        }
    }

    if tile.state == "failed": VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #7a1f1fd0;
            CutlassText {
                text: "Download failed — click to retry";
                style: { size: 10px, weight: 500, italic: false };
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
            }
        }
    }

    ta := TouchArea {
        clicked => {
            if tile.state != "downloading" && tile.state != "imported" {
                SfxBackend.import(root.index);
            }
        }
    }
}

// One animated-text preset (Library > Text > Presets): the sample text in
// the preset's fill color over a dark stage, a corner badge when look
// animations are attached, and the preset name strip. Drags exactly like
// GeneratedTile with the key "text-preset:<id>" — the drop resolver looks
// the preset up in the registry src/text_presets.rs filled and places a
// styled text clip.
export component TextPresetLibraryTile inherits Rectangle {
    in property <TextPresetTile> tile;

    property <int> fps-num: EditorStore.project.sequence.fps.num;
    property <int> fps-den: EditorStore.project.sequence.fps.den;

    background: AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;

    // Sample text on a dark stage.
    CutlassText {
        width: parent.width - 12px;
        height: parent.height - 22px;
        x: 6px;
        text: tile.sample;
        horizontal-alignment: center;
        vertical-alignment: center;
        style: { size: 16px, weight: 700, italic: false };
        foreground: tile.fill;
        wrap: word-wrap;
        overflow: elide;
    }

    // Animation badge.
    if tile.animated: Rectangle {
        x: 4px;
        y: 4px;
        width: anim-chip.preferred-width + 8px;
        height: 16px;
        border-radius: 3px;
        background: #000000a0;

        anim-chip := CutlassText {
            width: parent.width;
            text: "anim";
            horizontal-alignment: center;
            vertical-alignment: center;
            style: { size: 10px, weight: 500, italic: false };
            foreground: #ffffffcc;
        }
    }

    VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #000000a0;
            CutlassText {
                text: tile.name;
                style: AppStore.theme.typography.label;
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                AppState.library-drag-media-id = "";
                AppState.library-drag-generator = "text-preset:" + tile.key;
                AppState.library-drag-lane-kind = TrackKind.text;
                AppState.library-drag-duration-ticks =
                    max(1, round(3 * root.fps-num / root.fps-den));
                AppState.library-drag-w = root.width;
                AppState.library-drag-h = root.height;
                AppState.library-drag-tile-anchor-x = self.mouse-x;
                AppState.library-drag-tile-anchor-y = self.mouse-y;
                AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
                AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
                AppState.library-drag-active = true;
            }
            if event.kind == PointerEventKind.up {
                AppState.library-drag-active = false;
            }
            if event.kind == PointerEventKind.cancel {
                AppState.library-drag-cursor-x = -10000px;
                AppState.library-drag-cursor-y = -10000px;
                AppState.library-drag-active = false;
            }
        }

        moved => {
            if !self.pressed || !AppState.library-drag-active {
                return;
            }
            AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
            AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
        }
    }
}

// One AI generation result (Library > Media > AI media, Audio > AI
// generated). Click imports into the media pool once ready; the tile
// shows generation progress and failure states in place.
export component AiMediaTile inherits Rectangle {
    in property <AiItemTile> tile;
    in property <int> index;

    background: AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;

    if tile.has-thumbnail: Image {
        width: parent.width;
        height: parent.height;
        source: tile.thumbnail;
        image-fit: cover;
    }

    // TTS results have no picture; show a waveform-ish glyph instead.
    if !tile.has-thumbnail && tile.kind == "tts": CutlassText {
        width: parent.width;
        height: parent.height - 20px;
        text: "♪";
        horizontal-alignment: center;
        vertical-alignment: center;
        style: AppStore.theme.typography.heading-md;
    }

    // Prompt strip along the bottom.
    VerticalLayout {
        alignment: end;
        Rectangle {
            height: 20px;
            background: #000000a0;
            CutlassText {
                text: tile.label;
                style: { size: 10px, weight: 400, italic: false };
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
            }
        }
    }

    if tile.state == "generating": Rectangle {
        background: #00000080;
        CutlassText {
            width: parent.width;
            height: parent.height;
            text: "Generating…";
            horizontal-alignment: center;
            vertical-alignment: center;
            style: AppStore.theme.typography.caption;
        }
    }

    if tile.state == "failed": Rectangle {
        background: #00000080;
        CutlassText {
            width: parent.width;
            height: parent.height;
            text: "Failed";
            horizontal-alignment: center;
            vertical-alignment: center;
            style: AppStore.theme.typography.caption;
            foreground: #FF6B6B;
        }
    }

    if tile.state == "imported": Rectangle {
        x: parent.width - self.width - 4px;
        y: 4px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: AppStore.theme.accent.primary;

        CutlassText {
            width: parent.width;
            height: parent.height;
            text: "✓";
            horizontal-alignment: center;
            vertical-alignment: center;
            style: { size: 10px, weight: 700, italic: false };
            foreground: #000000;
        }
    }

    ta := TouchArea {
        mouse-cursor: tile.state == "ready" ? pointer : default;
        clicked => {
            if tile.state == "ready" {
                AiBackend.import(tile.kind, index);
            }
        }
    }
}
