// Library panel, CapCut-shaped: a tab strip across the top (Media / Audio /
// Text / Stickers), a section sidebar under it, and the active section's
// content filling the rest. Sections without a backend yet (stock browsing,
// AI generation) are honest "coming soon" placeholders so the navigation
// already has its final shape.

import {
    CutlassGridView,
    CutlassText,
    SubtleButton,
    PanelBase,
    VerticalDivider,
    HorizontalDivider,
} from "../../components/index.slint";
import { AppStore, EditorStore, TimelineStore } from "../../store/index.slint";
import { Media, TrackKind, CatalogEntry } from "../../models/index.slint";
import { EffectsBackend, CloudBackend, TextPresetsBackend } from "../../lib/index.slint";
import { MediaTile, GeneratedTile, CatalogTile, TransitionCatalogTile, StockMediaTile, TextPresetLibraryTile } from "tiles.slint";
import { SectionPlaceholder } from "placeholder.slint";
import { CutlassScrollView } from "../../components/scroll-view.slint";

// Active tab + per-tab section. A global rather than panel state: the panel
// unmounts while fullscreen preview is up, and the selection should survive
// the round trip.
global LibraryState {
    in-out property <string> active-tab: "media";
    in-out property <string> media-section: "local";
    in-out property <string> audio-section: "local";
    in-out property <string> text-section: "titles";
}

// Shared accent for active tab / section labels (same accent as AccentButton).
global LibraryStyle {
    out property <color> accent: AppStore.theme.accent.primary;
}

// One top tab: icon over label, CapCut-style (active = teal, no underline).
// Width hugs the label (CapCut-tight) so all eight tabs fit the panel's
// 350px minimum width.
component LibraryTab inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <string> tab-id;

    property <bool> active: LibraryState.active-tab == root.tab-id;
    property <color> ink: root.active ? LibraryStyle.accent
        : ta.has-hover ? AppStore.theme.text.primary
        : AppStore.theme.text.secondary;

    width: max(38px, lbl.preferred-width + 10px);
    background: transparent;

    VerticalLayout {
        alignment: center;
        spacing: 5px;

        HorizontalLayout {
            alignment: center;

            Image {
                width: 20px;
                height: 20px;
                source: root.icon;
                colorize: root.ink;
            }
        }

        lbl := CutlassText {
            text: root.label;
            horizontal-alignment: center;
            style: { size: 12px, weight: 600, italic: false };
            foreground: root.ink;
        }
    }

    ta := TouchArea {
        clicked => {
            LibraryState.active-tab = root.tab-id;
        }
    }
}

// One sidebar entry of the active tab's section list.
component SectionItem inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback activate();

    height: 28px;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: root.active ? #ffffff14
        : ta.has-hover ? #ffffff0a
        : transparent;

    CutlassText {
        x: AppStore.theme.metrics.spacing.sm;
        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
        height: parent.height;
        text: root.label;
        style: AppStore.theme.typography.label;
        foreground: root.active ? LibraryStyle.accent
            : ta.has-hover ? AppStore.theme.text.primary
            : AppStore.theme.text.secondary;
        vertical-alignment: center;
        overflow: elide;
    }

    ta := TouchArea {
        clicked => {
            root.activate();
        }
    }
}

component SectionList inherits VerticalLayout {
    in property <[{ id: string, label: string }]> sections;
    in property <string> active;
    callback select(id: string);

    // Narrow side padding buys label room ("Sound effects" must not elide
    // at the default pane width).
    padding-left: AppStore.theme.metrics.spacing.xs;
    padding-right: AppStore.theme.metrics.spacing.xs;
    padding-top: AppStore.theme.metrics.spacing.sm;
    padding-bottom: AppStore.theme.metrics.spacing.sm;
    spacing: AppStore.theme.metrics.spacing.xs;
    alignment: start;

    for s in root.sections: SectionItem {
        label: s.label;
        active: root.active == s.id;
        activate => {
            root.select(s.id);
        }
    }
}

// Search field for the stock browser, styled like the settings text field.
component StockSearchField inherits Rectangle {
    height: 28px;
    horizontal-stretch: 1;
    border-radius: AppStore.theme.metrics.radius.sm;
    background: #111111;
    border-width: 1px;
    border-color: input.has-focus ? AppStore.theme.accent.primary : #ffffff14;
    clip: true;
    forward-focus: input;

    input := TextInput {
        x: AppStore.theme.metrics.spacing.sm;
        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
        height: parent.height;
        vertical-alignment: center;
        single-line: true;
        text <=> CloudBackend.stock-query;
        color: AppStore.theme.text.primary;
        font-size: AppStore.theme.typography.body.size;
        selection-background-color: AppStore.theme.accent.primary.with-alpha(0.33);
        selection-foreground-color: AppStore.theme.text.primary;
        accessible-role: none;
        accepted => {
            CloudBackend.stock-search();
        }
    }

    if CloudBackend.stock-query == "" && !input.has-focus: CutlassText {
        x: AppStore.theme.metrics.spacing.sm;
        width: parent.width - 2 * AppStore.theme.metrics.spacing.sm;
        height: parent.height;
        vertical-alignment: center;
        text: "Search stock media…";
        style: AppStore.theme.typography.body;
        foreground: AppStore.theme.text.muted;
        overflow: elide;
    }
}

// Videos / Photos toggle chip for the stock browser.
component StockKindChip inherits Rectangle {
    in property <string> kind;
    in property <string> label;

    property <bool> active: CloudBackend.stock-kind == root.kind;

    width: lbl.preferred-width + 16px;
    height: 24px;
    border-radius: 12px;
    background: root.active ? AppStore.theme.accent.primary.with-alpha(0.22)
        : ta.has-hover ? #ffffff0a
        : transparent;
    border-width: 1px;
    border-color: root.active ? AppStore.theme.accent.primary : #ffffff14;

    lbl := CutlassText {
        text: root.label;
        style: { size: 11px, weight: 600, italic: false };
        foreground: root.active ? AppStore.theme.accent.primary : AppStore.theme.text.secondary;
    }

    ta := TouchArea {
        clicked => {
            if CloudBackend.stock-kind != root.kind {
                CloudBackend.stock-kind = root.kind;
                if CloudBackend.stock-query != "" {
                    CloudBackend.stock-search();
                }
            }
        }
    }
}

// Import row shown atop the Local sections (media + audio share the same
// picker; main.rs owns the async dialog).
component ImportToolbar inherits HorizontalLayout {
    padding: AppStore.theme.metrics.spacing.sm;
    alignment: start;

    SubtleButton {
        label: "+  Import";
        clicked => {
            EditorStore.on-import-clicked();
        }
    }
}

export component LibraryPanel inherits PanelBase {
    // Read-only projections of the engine media pool (see src/projection.rs).
    property <[Media]> media: EditorStore.project.media;
    property <[Media]> audio-media: EditorStore.project.media-audio;

    VerticalLayout {
        spacing: AppStore.theme.metrics.spacing.none;

        // ---- Tab strip ----------------------------------------------------
        Rectangle {
            height: 52px;
            background: AppStore.theme.panel.header-background;
            CutlassScrollView {
                height: parent.height;
                viewport-width: tabs.preferred-width;
                viewport-height: self.height;
                show-horizontal-scrollbar: false;
                show-vertical-scrollbar: false;

                tabs := HorizontalLayout {
                    padding-left: AppStore.theme.metrics.spacing.xs;
                    alignment: start;
                    spacing: AppStore.theme.metrics.spacing.md;

                    LibraryTab {
                        tab-id: "media";
                        icon: @image-url("../../../../../assets/icon/library/media.svg");
                        label: "Media";
                    }

                    LibraryTab {
                        tab-id: "audio";
                        icon: @image-url("../../../../../assets/icon/library/audio.svg");
                        label: "Audio";
                    }

                    LibraryTab {
                        tab-id: "text";
                        icon: @image-url("../../../../../assets/icon/library/text.svg");
                        label: "Text";
                    }

                    LibraryTab {
                        tab-id: "stickers";
                        icon: @image-url("../../../../../assets/icon/library/stickers.svg");
                        label: "Stickers";
                    }

                    LibraryTab {
                        tab-id: "effects";
                        icon: @image-url("../../../../../assets/icon/library/effects.svg");
                        label: "Effects";
                    }

                    LibraryTab {
                        tab-id: "transitions";
                        icon: @image-url("../../../../../assets/icon/library/transitions.svg");
                        label: "Transitions";
                    }

                    // Filters / Adjustment tabs return when their engines land
                // (v1 roadmap M5). The model's TrackKind catalog keeps those
                // lanes; the UI hides dead features until then.
                }
            }
        }

        HorizontalDivider { }

        // ---- Sidebar + content ---------------------------------------------
        HorizontalLayout {
            vertical-stretch: 1;
            spacing: AppStore.theme.metrics.spacing.none;

            Rectangle {
                width: 112px;

                if LibraryState.active-tab == "media": SectionList {
                    width: parent.width;
                    sections: [
                        { id: "local", label: "Local" },
                        { id: "stock", label: "Stock" },
                        { id: "ai", label: "AI media" },
                    ];
                    active: LibraryState.media-section;
                    select(id) => {
                        LibraryState.media-section = id;
                    }
                }

                if LibraryState.active-tab == "audio": SectionList {
                    width: parent.width;
                    sections: [
                        { id: "local", label: "Local" },
                        { id: "sfx", label: "Sound effects" },
                        { id: "stock", label: "Stock music" },
                        { id: "ai", label: "AI generated" },
                    ];
                    active: LibraryState.audio-section;
                    select(id) => {
                        LibraryState.audio-section = id;
                    }
                }

                if LibraryState.active-tab == "text": SectionList {
                    width: parent.width;
                    sections: [
                        { id: "titles", label: "Add text" },
                        { id: "presets", label: "Presets" },
                    ];
                    active: LibraryState.text-section;
                    select(id) => {
                        LibraryState.text-section = id;
                        if id == "presets" && TextPresetsBackend.status == "idle" {
                            TextPresetsBackend.refresh();
                        }
                    }
                }

                if LibraryState.active-tab == "stickers": SectionList {
                    width: parent.width;
                    sections: [{ id: "shapes", label: "Shapes" }];
                    active: "shapes";
                }

                if LibraryState.active-tab == "effects": SectionList {
                    width: parent.width;
                    sections: [{ id: "all", label: "All effects" }];
                    active: "all";
                }

                if LibraryState.active-tab == "transitions": SectionList {
                    width: parent.width;
                    sections: [{ id: "all", label: "All transitions" }];
                    active: "all";
                }
            }

            VerticalDivider { }

            Rectangle {
                horizontal-stretch: 1;

                // ---- Media > Local ------------------------------------------
                if LibraryState.active-tab == "media" && LibraryState.media-section == "local": VerticalLayout {
                    spacing: AppStore.theme.metrics.spacing.none;

                    ImportToolbar { }

                    media-grid := CutlassGridView {
                        show-horizontal-scrollbar: false;
                        show-vertical-scrollbar: false;
                        interactive: false;
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        // As many 100px columns as the pane width allows.
                        columns: max(1, floor((self.width - AppStore.theme.metrics.spacing.md)
                            / (100px + AppStore.theme.metrics.spacing.md)));
                        cell-width: 100px;
                        cell-height: 100px;
                        spacing: AppStore.theme.metrics.spacing.md;
                        inset: AppStore.theme.metrics.spacing.md;
                        item-count: root.media.length;

                        for m[i] in root.media: MediaTile {
                            x: media-grid.cell-x(i);
                            y: media-grid.cell-y(i);
                            width: media-grid.cell-width;
                            height: media-grid.cell-height;
                            media: m;
                        }
                    }
                }

                // ---- Media > Stock ------------------------------------------
                // Search metadata comes from the backend (or directly from the
                // providers with BYOK stock keys); media files download straight
                // from the provider CDNs. Importing a result lands it in the
                // pool under Local like any other media (src/cloud.rs).
                if LibraryState.active-tab == "media" && LibraryState.media-section == "stock": VerticalLayout {
                    spacing: AppStore.theme.metrics.spacing.none;

                    HorizontalLayout {
                        padding: AppStore.theme.metrics.spacing.sm;
                        spacing: AppStore.theme.metrics.spacing.sm;

                        StockSearchField { }

                        StockKindChip {
                            kind: "video";
                            label: "Videos";
                        }

                        StockKindChip {
                            kind: "photo";
                            label: "Photos";
                        }
                    }

                    if CloudBackend.stock-status == "idle": SectionPlaceholder {
                        vertical-stretch: 1;
                        icon: @image-url("../../../../../assets/icon/library/stock.svg");
                        title: "Stock library";
                        message: "Royalty-free clips and photos from Pexels and Pixabay. Type a search above to browse.";
                    }

                    if CloudBackend.stock-status == "searching": VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;

                        CutlassText {
                            text: "Searching…";
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                            horizontal-alignment: center;
                        }
                    }

                    if CloudBackend.stock-status == "empty": VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        padding: AppStore.theme.metrics.spacing.xl;

                        CutlassText {
                            text: "No results — try a different search.";
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }

                    if CloudBackend.stock-status == "error": VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        padding: AppStore.theme.metrics.spacing.xl;
                        spacing: AppStore.theme.metrics.spacing.sm;

                        CutlassText {
                            text: "Search failed";
                            style: AppStore.theme.typography.heading-sm;
                            horizontal-alignment: center;
                        }

                        CutlassText {
                            text: CloudBackend.stock-error;
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            alignment: center;
                            SubtleButton {
                                label: "Retry";
                                clicked => {
                                    CloudBackend.stock-search();
                                }
                            }
                        }
                    }

                    if CloudBackend.stock-status == "results": VerticalLayout {
                        vertical-stretch: 1;
                        spacing: AppStore.theme.metrics.spacing.none;

                        stock-grid := CutlassGridView {
                            show-horizontal-scrollbar: false;
                            show-vertical-scrollbar: false;
                            interactive: false;
                            vertical-stretch: 1;
                            horizontal-stretch: 1;

                            columns: max(1, floor((self.width - AppStore.theme.metrics.spacing.md)
                                / (100px + AppStore.theme.metrics.spacing.md)));
                            cell-width: 100px;
                            cell-height: 100px;
                            spacing: AppStore.theme.metrics.spacing.md;
                            inset: AppStore.theme.metrics.spacing.md;
                            item-count: CloudBackend.stock-items.length;

                            for tile[i] in CloudBackend.stock-items: StockMediaTile {
                                x: stock-grid.cell-x(i);
                                y: stock-grid.cell-y(i);
                                width: stock-grid.cell-width;
                                height: stock-grid.cell-height;
                                tile: tile;
                                index: i;
                            }
                        }

                        if CloudBackend.stock-has-more: HorizontalLayout {
                            padding: AppStore.theme.metrics.spacing.sm;
                            alignment: center;

                            SubtleButton {
                                label: CloudBackend.stock-loading-more ? "Loading…" : "Load more";
                                clicked => {
                                    if !CloudBackend.stock-loading-more {
                                        CloudBackend.stock-load-more();
                                    }
                                }
                            }
                        }
                    }
                }

                if LibraryState.active-tab == "media" && LibraryState.media-section == "ai": SectionPlaceholder {
                    width: parent.width;
                    height: parent.height;
                    icon: @image-url("../../../../../assets/icon/library/ai.svg");
                    title: "AI media";
                    message: "Generate images and video clips from a prompt, straight into the library. Coming soon.";
                }

                // ---- Audio > Local ------------------------------------------
                if LibraryState.active-tab == "audio" && LibraryState.audio-section == "local": VerticalLayout {
                    spacing: AppStore.theme.metrics.spacing.none;

                    ImportToolbar { }

                    if root.audio-media.length == 0: VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        padding: AppStore.theme.metrics.spacing.xl;
                        spacing: AppStore.theme.metrics.spacing.sm;

                        CutlassText {
                            text: "No audio yet";
                            style: AppStore.theme.typography.heading-sm;
                            horizontal-alignment: center;
                        }

                        CutlassText {
                            text: "Audio files you import show up here, ready to drag onto the timeline.";
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }

                    if root.audio-media.length > 0: audio-grid := CutlassGridView {
                        show-horizontal-scrollbar: false;
                        show-vertical-scrollbar: false;
                        interactive: false;
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        columns: max(1, floor((self.width - AppStore.theme.metrics.spacing.md)
                            / (100px + AppStore.theme.metrics.spacing.md)));
                        cell-width: 100px;
                        cell-height: 100px;
                        spacing: AppStore.theme.metrics.spacing.md;
                        inset: AppStore.theme.metrics.spacing.md;
                        item-count: root.audio-media.length;

                        for m[i] in root.audio-media: MediaTile {
                            x: audio-grid.cell-x(i);
                            y: audio-grid.cell-y(i);
                            width: audio-grid.cell-width;
                            height: audio-grid.cell-height;
                            media: m;
                        }
                    }
                }

                // ---- Audio > SFX / Stock / AI -------------------------------
                if LibraryState.active-tab == "audio" && LibraryState.audio-section == "sfx": SectionPlaceholder {
                    width: parent.width;
                    height: parent.height;
                    icon: @image-url("../../../../../assets/icon/library/sfx.svg");
                    title: "Sound effects";
                    message: "A built-in pack of whooshes, dings, and ambience. Coming soon.";
                }

                if LibraryState.active-tab == "audio" && LibraryState.audio-section == "stock": SectionPlaceholder {
                    width: parent.width;
                    height: parent.height;
                    icon: @image-url("../../../../../assets/icon/library/audio.svg");
                    title: "Stock music";
                    message: "Royalty-free tracks to score your edit. Coming soon.";
                }

                if LibraryState.active-tab == "audio" && LibraryState.audio-section == "ai": SectionPlaceholder {
                    width: parent.width;
                    height: parent.height;
                    icon: @image-url("../../../../../assets/icon/library/ai.svg");
                    title: "AI generated";
                    message: "Generate music and voice-overs from a prompt. Coming soon.";
                }

                // ---- Text > Add text ----------------------------------------
                if LibraryState.active-tab == "text" && LibraryState.text-section == "titles": text-grid := CutlassGridView {
                    width: parent.width;
                    height: parent.height;
                    show-horizontal-scrollbar: false;
                    show-vertical-scrollbar: false;
                    interactive: false;

                    columns: max(1, floor((self.width - AppStore.theme.metrics.spacing.md)
                        / (100px + AppStore.theme.metrics.spacing.md)));
                    cell-width: 100px;
                    cell-height: 100px;
                    spacing: AppStore.theme.metrics.spacing.md;
                    inset: AppStore.theme.metrics.spacing.md;
                    item-count: 1;

                    GeneratedTile {
                        x: text-grid.cell-x(0);
                        y: text-grid.cell-y(0);
                        width: text-grid.cell-width;
                        height: text-grid.cell-height;
                        generator: "text";
                        label: "Default text";
                        lane-kind: TrackKind.text;
                        seconds: 3;
                        swatch: #3A6FC8;
                    }
                }

                // ---- Text > Presets -----------------------------------------
                // Served recipes (TextStyle + look-animation combos) rendered
                // by the existing text pipeline; tiles drag onto the timeline
                // like the default text tile (src/text_presets.rs).
                if LibraryState.active-tab == "text" && LibraryState.text-section == "presets": VerticalLayout {
                    spacing: AppStore.theme.metrics.spacing.none;

                    if TextPresetsBackend.status == "idle" || TextPresetsBackend.status == "loading": VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;

                        CutlassText {
                            text: "Loading presets…";
                            horizontal-alignment: center;
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                        }
                    }

                    if TextPresetsBackend.status == "empty": SectionPlaceholder {
                        vertical-stretch: 1;
                        icon: @image-url("../../../../../assets/icon/library/text.svg");
                        title: "Text presets";
                        message: "Styled, animated title recipes land here as the catalog grows.";
                    }

                    if TextPresetsBackend.status == "error": VerticalLayout {
                        vertical-stretch: 1;
                        alignment: center;
                        padding: AppStore.theme.metrics.spacing.xl;
                        spacing: AppStore.theme.metrics.spacing.sm;

                        CutlassText {
                            text: "Couldn't load presets";
                            style: AppStore.theme.typography.heading-sm;
                            horizontal-alignment: center;
                        }

                        CutlassText {
                            text: TextPresetsBackend.error;
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            alignment: center;
                            SubtleButton {
                                label: "Retry";
                                clicked => {
                                    TextPresetsBackend.refresh();
                                }
                            }
                        }
                    }

                    if TextPresetsBackend.status == "results": preset-grid := CutlassGridView {
                        show-horizontal-scrollbar: false;
                        show-vertical-scrollbar: false;
                        interactive: false;
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        columns: max(1, floor((self.width - AppStore.theme.metrics.spacing.md)
                            / (100px + AppStore.theme.metrics.spacing.md)));
                        cell-width: 100px;
                        cell-height: 100px;
                        spacing: AppStore.theme.metrics.spacing.md;
                        inset: AppStore.theme.metrics.spacing.md;
                        item-count: TextPresetsBackend.items.length;

                        for tile[i] in TextPresetsBackend.items: TextPresetLibraryTile {
                            x: preset-grid.cell-x(i);
                            y: preset-grid.cell-y(i);
                            width: preset-grid.cell-width;
                            height: preset-grid.cell-height;
                            tile: tile;
                        }
                    }
                }

                // ---- Stickers (bundled pack + shapes) -----------------------
                if LibraryState.active-tab == "stickers": shape-grid := CutlassGridView {
                    width: parent.width;
                    height: parent.height;
                    show-horizontal-scrollbar: false;
                    show-vertical-scrollbar: false;
                    interactive: false;

                    columns: max(1, floor((self.width - AppStore.theme.metrics.spacing.md)
                        / (100px + AppStore.theme.metrics.spacing.md)));
                    cell-width: 100px;
                    cell-height: 100px;
                    spacing: AppStore.theme.metrics.spacing.md;
                    inset: AppStore.theme.metrics.spacing.md;
                    item-count: EffectsBackend.sticker-catalog.length + 3;

                    for sticker[i] in EffectsBackend.sticker-catalog: GeneratedTile {
                        x: shape-grid.cell-x(i);
                        y: shape-grid.cell-y(i);
                        width: shape-grid.cell-width;
                        height: shape-grid.cell-height;
                        generator: "sticker:" + sticker.id;
                        label: sticker.label;
                        icon: sticker.icon;
                        lane-kind: TrackKind.sticker;
                        seconds: 5;
                    }

                    GeneratedTile {
                        x: shape-grid.cell-x(EffectsBackend.sticker-catalog.length + 0);
                        y: shape-grid.cell-y(EffectsBackend.sticker-catalog.length + 0);
                        width: shape-grid.cell-width;
                        height: shape-grid.cell-height;
                        generator: "solid";
                        label: "Solid";
                        lane-kind: TrackKind.sticker;
                        seconds: 5;
                        swatch: #1E1E1E;
                    }

                    GeneratedTile {
                        x: shape-grid.cell-x(EffectsBackend.sticker-catalog.length + 1);
                        y: shape-grid.cell-y(EffectsBackend.sticker-catalog.length + 1);
                        width: shape-grid.cell-width;
                        height: shape-grid.cell-height;
                        generator: "rect";
                        label: "Rectangle";
                        lane-kind: TrackKind.sticker;
                        seconds: 5;
                        swatch: #E0E0E0;
                    }

                    GeneratedTile {
                        x: shape-grid.cell-x(EffectsBackend.sticker-catalog.length + 2);
                        y: shape-grid.cell-y(EffectsBackend.sticker-catalog.length + 2);
                        width: shape-grid.cell-width;
                        height: shape-grid.cell-height;
                        generator: "ellipse";
                        label: "Ellipse";
                        lane-kind: TrackKind.sticker;
                        seconds: 5;
                        swatch: #E0E0E0;
                        round-swatch: true;
                    }
                }

                // ---- Effects ------------------------------------------------
                // Click applies to the selected clip's chain; drag drops a
                // standalone effect segment onto an effect lane (CapCut's
                // effect-as-track-clip, affecting everything beneath it).
                if LibraryState.active-tab == "effects": VerticalLayout {
                    spacing: AppStore.theme.metrics.spacing.none;

                    Rectangle {
                        height: 34px;
                        background: AppStore.theme.panel.header-background;
                        CutlassText {
                            x: AppStore.theme.metrics.spacing.md;
                            width: parent.width - 2 * AppStore.theme.metrics.spacing.md;
                            height: parent.height;
                            vertical-alignment: center;
                            text: TimelineStore.selected-clip-id == ""
                                ? "Drag an effect to the timeline, or select a clip and click"
                                : "Click to add to the selected clip, or drag to the timeline";
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                            overflow: elide;
                        }
                    }

                    effects-grid := CutlassGridView {
                        show-horizontal-scrollbar: false;
                        show-vertical-scrollbar: false;
                        interactive: false;
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        columns: max(1, floor((self.width - AppStore.theme.metrics.spacing.md)
                            / (100px + AppStore.theme.metrics.spacing.md)));
                        cell-width: 100px;
                        cell-height: 100px;
                        spacing: AppStore.theme.metrics.spacing.md;
                        inset: AppStore.theme.metrics.spacing.md;
                        item-count: EffectsBackend.effect-catalog.length;

                        for fx[i] in EffectsBackend.effect-catalog: CatalogTile {
                            x: effects-grid.cell-x(i);
                            y: effects-grid.cell-y(i);
                            width: effects-grid.cell-width;
                            height: effects-grid.cell-height;
                            label: fx.label;
                            swatch: #6C4AC8;
                            enabled: TimelineStore.selected-clip-id != "";
                            generator: "effect:" + fx.id;
                            lane-kind: TrackKind.effect;
                            seconds: 3;
                            apply => {
                                EffectsBackend.add-effect(TimelineStore.selected-clip-id, fx.id);
                            }
                        }
                    }
                }

                // ---- Transitions --------------------------------------------
                // Drag onto a clip junction, or click to apply at the selected
                // clip's right edge.
                if LibraryState.active-tab == "transitions": VerticalLayout {
                    spacing: AppStore.theme.metrics.spacing.none;

                    Rectangle {
                        height: 34px;
                        background: AppStore.theme.panel.header-background;
                        CutlassText {
                            x: AppStore.theme.metrics.spacing.md;
                            width: parent.width - 2 * AppStore.theme.metrics.spacing.md;
                            height: parent.height;
                            vertical-alignment: center;
                            text: "Drag onto a cut, or click with a clip selected";
                            style: AppStore.theme.typography.caption;
                            foreground: AppStore.theme.text.secondary;
                            overflow: elide;
                        }
                    }

                    transitions-grid := CutlassGridView {
                        show-horizontal-scrollbar: false;
                        show-vertical-scrollbar: false;
                        interactive: false;
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        columns: max(1, floor((self.width - AppStore.theme.metrics.spacing.md)
                            / (100px + AppStore.theme.metrics.spacing.md)));
                        cell-width: 100px;
                        cell-height: 100px;
                        spacing: AppStore.theme.metrics.spacing.md;
                        inset: AppStore.theme.metrics.spacing.md;
                        item-count: EffectsBackend.transition-catalog.length;

                        for tr[i] in EffectsBackend.transition-catalog: TransitionCatalogTile {
                            x: transitions-grid.cell-x(i);
                            y: transitions-grid.cell-y(i);
                            width: transitions-grid.cell-width;
                            height: transitions-grid.cell-height;
                            transition-id: tr.id;
                            label: tr.label;
                        }
                    }
                }
            }
        }
    }
}
