import {
    CutlassGridView,
    CutlassGridCell,
} from "../../components/grid-view.slint";

export component LibraryPanel inherits VerticalLayout {
    spacing: 0;

    // Single source of truth for the placeholder bin. When the real
    // media model lands this becomes `AppState.media-bin` and both the
    // for-loop and `item-count` source from the same length.
    property <int> tile-count: 30;

    grid := CutlassGridView {
        vertical-stretch: 1;
        horizontal-stretch: 1;

        columns: 3;
        cell-width: 100px;
        cell-height: 100px;
        spacing: 10px;
        inset: 10px;
        // Must match the for-loop iteration count: drives `content-height`,
        // which in turn drives whether the scroll view shows a bar at all.
        item-count: tile-count;

        for _[i] in tile-count: CutlassGridCell {
            metrics: grid.metrics;
            index: i;

            Rectangle {
                width: 100%;
                height: 100%;
                background: #000000;
            }
        }
    }
}
