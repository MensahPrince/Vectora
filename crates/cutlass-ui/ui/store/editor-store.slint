import { Project } from "../models/index.slint";

// View model for the open project. Rust sets this once at startup, then
// patches it after engine commands.
export global EditorStore {
    in-out property <Project> project: {
        id: "",
        title: "",
        sequence: {
            id: "",
            name: "",
            fps: { num: 24, den: 1 },
            drop-frame: false,
            width: 1920px,
            height: 1080px,
            tracks: [],
        },
    };

    callback move-clip(
        string /* source-track-id */,
        string /* clip-id */,
        string /* target-track-id */,
        int    /* new-start-value */,
    );
}
