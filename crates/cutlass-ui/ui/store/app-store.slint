import { Theme } from "../types/index.slint";
import { DarkBlueTheme, EmberTheme, DefaultTheme } from "../theme/index.slint";

export global AppStore {
    // Ember is the shipped look; DefaultTheme (cool graphite + teal) stays
    // available — point this binding at it to switch back.
    in-out property <Theme> theme: DarkBlueTheme.theme;
}
