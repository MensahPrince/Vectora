// The clip's effect chain (M4), one block per effect: a header with the
// catalog label and a remove button, then a slider per scalar parameter. The
// chain index drives `remove-effect` / `set-effect-param`, so the order here
// matches the engine's apply order.
//
// Param values come from the clip-start projection and re-sync on every
// republish, so a committed edit lands back through the projection rather
// than being held UI-side. Release / Enter commit one undoable
// `SetEffectParam`; animated edits go through the keyframe path (a
// deliberate follow-up).

import { CutlassText, SubtleButton } from "../../components/index.slint";
import { AppStore } from "../../store/index.slint";
import { Clip, EffectView, EffectParamView } from "../../models/index.slint";
import { EffectsBackend } from "../../lib/index.slint";
import { SectionHeader, SliderRow } from "inspector-widgets.slint";

export component EffectsInspector inherits VerticalLayout {
    // Named `model` — `clip` is a built-in boolean on Slint elements.
    in property <Clip> model;

    spacing: AppStore.theme.metrics.spacing.lg;
    alignment: LayoutAlignment.start;

    SectionHeader {
        title: "Effects";
    }

    if root.model.effects.length == 0: CutlassText {
        text: "No effects yet. Add one from the Effects library.";
        style: AppStore.theme.typography.caption;
        foreground: AppStore.theme.text.secondary;
        wrap: TextWrap.word-wrap;
    }

    for fx[i] in root.model.effects: VerticalLayout {
        spacing: AppStore.theme.metrics.spacing.sm;

        HorizontalLayout {
            spacing: AppStore.theme.metrics.spacing.sm;
            height: 26px;
            vertical-stretch: 0;

            CutlassText {
                text: fx.label;
                style: AppStore.theme.typography.label;
                foreground: AppStore.theme.text.primary;
                vertical-alignment: TextVerticalAlignment.center;
                horizontal-stretch: 1;
                overflow: TextOverflow.elide;
            }

            SubtleButton {
                label: "Remove";
                clicked => {
                    EffectsBackend.remove-effect(root.model.id, i);
                }
            }
        }

        for p in fx.params: SliderRow {
            label: p.label;
            value: p.value;
            minimum: p.min;
            maximum: p.max;
            step: max(0.001, (p.max - p.min) / 200);
            decimals: 2;
            // Double-click reset: zero when the range allows it (the neutral
            // value for blur/intensity-style params), otherwise the minimum.
            reset-value: clamp(0, p.min, p.max);
            commit(v) => {
                EffectsBackend.set-effect-param(root.model.id, i, p.name, clamp(v, p.min, p.max));
            }
        }
    }
}
