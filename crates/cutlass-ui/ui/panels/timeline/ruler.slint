// CapCut-style timeline ruler.
//
// Visual layout (CapCut convention, ~30 px strip):
//
//   +---------------------------------------------------------------+
//   |  |00:00:00:00         |00:00:01:00         |00:00:02:00      |
//   |    .    .    .    .    .    .    .    .    .    .    .    .  |
//   +---------------------------------------------------------------+
//
// Coordinate model:
//
//   This component lives inside a clipping `Rectangle` in `timeline.slint`
//   and stays put at x=0 within that container — it does NOT translate
//   with the scroll. Instead it reads `TimelineViewState.scroll-x` and
//   passes it to the Rust backend, which returns ticks already
//   positioned in *viewport-local* pixels (`frame * zoom + scroll_x`).
//
//   The playhead handle uses the same projection. Scrubbing converts
//   viewport-local `mouse-x` back to ticks via
//   `round((mouse-x - scroll-x) / zoom)`.

import { AppStore, TimelineStore, EditorStore } from "../../store/index.slint";
import { CutlassText } from "../../components/index.slint";
import { TimelineViewState } from "state.slint";
import { RulerBackend, RulerTick } from "../../lib/ruler-backend.slint";

export component Ruler inherits Rectangle {
    in property <length> content-width: 0px;

    private property <length> scroll-x: TimelineViewState.scroll-x;
    private property <float> zoom: TimelineStore.zoom;
    private property <int> fps-num: EditorStore.project.sequence.fps.num;
    private property <int> fps-den: EditorStore.project.sequence.fps.den;
    private property <bool> drop-frame: EditorStore.project.sequence.drop-frame;

    private property <[RulerTick]> tick-model:
        RulerBackend.ticks(scroll-x, self.width, zoom, fps-num, fps-den, drop-frame);

    for tick in tick-model: Rectangle {
        x: tick.x;
        y: tick.is-major ? 4px : 11px;
        width: AppStore.theme.metrics.stroke.hairline;
        height: tick.is-major ? 10px : 3px;
        background: tick.is-major ? AppStore.theme.text.secondary : AppStore.theme.text.muted;
    }

    for tick in tick-model: CutlassText {
        x: tick.x + 2px;
        y: 4px;
        text: tick.label;
        mono: true;
        style: AppStore.theme.typography.caption;
        foreground: AppStore.theme.text.secondary;
    }

    scrub := TouchArea {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        mouse-cursor: MouseCursor.text;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                TimelineStore.playhead-tick = max(
                    0,
                    round((scrub.mouse-x - scroll-x) / 1px / TimelineStore.zoom),
                );
            }
        }

        moved => {
            if !scrub.pressed {
                return;
            }
            TimelineStore.playhead-tick = max(
                0,
                round((scrub.mouse-x - scroll-x) / 1px / TimelineStore.zoom),
            );
        }
    }

    Rectangle {
        x: TimelineStore.playhead-tick * TimelineStore.zoom * 1px + scroll-x - 4px;
        y: 0;
        width: 9px;
        height: 14px;
        background: #ffffff;
        border-radius: 2px;
    }

    Rectangle {
        x: TimelineStore.playhead-tick * TimelineStore.zoom * 1px + scroll-x;
        y: 0;
        width: 1px;
        height: parent.height;
        background: #ffffff;
    }
}
