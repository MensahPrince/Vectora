import { TimelineLib } from "../../lib/index.slint";
import { AppStore, EditorStore, TimelineStore } from "../../store/index.slint";

// Panel-local *view* state for the timeline. Anything in here is
// ephemeral UI ("where is the user currently looking?", "which clip
// is the cursor dragging right now?", "where would the dragged clip
// land if released right now?") and is not part of the project, not
// persisted, and not addressable by the agent command layer.
//
// Drag semantics:
//
//   * The view shows the dragged clip at its committed
//     (`timeline-start`, source lane) offset by `drag-dx-px` /
//     `drag-dy-px` while a drag is in progress.
//   * The gesture layer dispatches exactly one
//     `EditorStore.move-clip` command on release with
//     `(source-track-id, clip-id, target-track-id, new-start-value)`.
//     Rust applies its collision / new-lane policy in that single
//     command — the UI never has to encode the policy.
//
// Domain timeline state (zoom, playhead, selection, marks, …) lives
// in `TimelineStore` (`ui/store/timeline-store.slint`).
export global TimelineViewState {
    in-out property <length> scroll-x: 0px;
    in-out property <length> scroll-y: 0px;

    // ---- active drag identity --------------------------------------
    //
    // Identifies the clip currently being dragged. Empty
    // `dragging-clip-id` ⇔ no drag in progress. We key on
    // (source-track-id, clip-id) because clip ids are unique per
    // track, not project-wide. The "source" side never changes during
    // the drag (the clip stays committed there until release); the
    // *target* track id below tracks where the cursor currently
    // hovers.
    in-out property <string> dragging-source-track-id: "";
    in-out property <string> dragging-clip-id: "";

    // ---- ephemeral drag offsets ------------------------------------
    //
    // Pixel offset of the dragged clip from its committed
    // `(timeline-start * zoom, source-lane-y)` position. Reset to
    // `0px` on release. Only one clip can be dragged at a time, so a
    // single pair of scalars is enough.
    in-out property <length> drag-dx-px: 0px;
    in-out property <length> drag-dy-px: 0px;

    // ---- target lane resolution -----------------------------------
    //
    // Computed by the gesture layer from `drag-dy-px` + lane pitch +
    // the source lane's index in `track-order`. Empty when the
    // hovered lane isn't a valid drop target (wrong kind, or no lane
    // under the cursor). Rendered as a highlight on the matching
    // `TrackLane` and used as `target-track-id` in the release
    // command.
    in-out property <string> drag-target-track-id: "";

    // ---- snap state ------------------------------------------------
    //
    // Populated by `DragBackend.snap-clip-start` on every drag frame.
    // When `drag-snap-active` is true, the timeline overlays a thin
    // vertical guide at `drag-snap-tick * zoom`. The snapped start
    // value is what gets sent in the release command.
    in-out property <bool> drag-snap-active: false;
    in-out property <int> drag-snap-tick: 0;
    in-out property <int> drag-snapped-start-value: 0;
}
