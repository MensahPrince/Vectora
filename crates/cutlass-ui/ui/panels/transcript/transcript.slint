// Transcript-based editing panel (M9 Phase 3) — the AI-first flagship. For the
// selected media clip, "Transcribe" decodes its speech and shows the words;
// selecting a run of words and hitting Delete ripple-cuts their timeline span
// out of the clip, so editing the text edits the video. Captions and the AI
// agent share the same transcribe substrate (cutlass-ml).
//
// All state lives in TranscriptStore; the preview worker fills the lines after a
// transcribe and main.rs forwards the callbacks (and applies the reflow). Words
// are rendered as clickable chips grouped into worker-packed lines, since Slint
// has no flow layout.

import {
    PanelBase,
    PanelHeader,
    CutlassScrollView,
    CutlassText,
    AccentButton,
    SubtleButton,
} from "../../components/index.slint";
import { AppStore, EditorStore, TimelineStore, TranscriptStore, TranscriptWord, TranscriptLine } from "../../store/index.slint";
import { InspectorBackend, SelectedClipInfo } from "../../lib/inspector-backend.slint";

// One clickable word. Click selects (and seeks the playhead to the word);
// Shift-click extends the selection. Deleted words are struck out and inert.
component WordChip inherits Rectangle {
    in property <TranscriptWord> word;

    private property <bool> selected: TranscriptStore.selected(word.index);

    border-radius: AppStore.theme.metrics.radius.sm;
    background: selected
        ? AppStore.theme.accent.primary.with-alpha(0.30)
        : (ta.has-hover && !word.deleted ? #ffffff14 : transparent);

    HorizontalLayout {
        padding-left: 3px;
        padding-right: 3px;
        padding-top: 1px;
        padding-bottom: 1px;

        label := CutlassText {
            text: word.text;
            style: AppStore.theme.typography.body;
            foreground: word.deleted
                ? AppStore.theme.text.muted
                : (selected ? AppStore.theme.text.primary : AppStore.theme.text.secondary);
            opacity: word.deleted ? 0.5 : 1.0;
        }
    }

    // Strike-through for an already-cut word.
    if word.deleted: Rectangle {
        x: 3px;
        width: parent.width - 6px;
        height: 1px;
        background: AppStore.theme.text.muted;
    }

    ta := TouchArea {
        enabled: !word.deleted;
        mouse-cursor: MouseCursor.pointer;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                if (e.modifiers.shift) {
                    TranscriptStore.extend-to(word.index);
                } else {
                    TranscriptStore.select-word(word.index);
                    // Click-to-seek: park the playhead at the word's start.
                    TimelineStore.playhead-tick = word.start-tick;
                }
            }
        }
    }
}

export component TranscriptPanel inherits PanelBase {
    private property <SelectedClipInfo> selection: InspectorBackend.resolve-selection(
        EditorStore.project.sequence,
        TimelineStore.selected-track-id,
        TimelineStore.selected-clip-id,
    );
    // A media clip at normal speed can be transcribed (matches the captions
    // gate: the linear seconds→tick map only holds at 1×).
    private property <bool> transcribable: selection.found
        && selection.clip.media-id != ""
        && selection.clip.speed-label == "";

    // Drop a stale transcript when the selection moves to another clip — the
    // words and their ticks belong to the clip they were transcribed from.
    private property <string> sel-clip: TimelineStore.selected-clip-id;
    changed sel-clip => {
        if (sel-clip != TranscriptStore.track-id) {
            TranscriptStore.lines = [];
            TranscriptStore.word-count = 0;
            TranscriptStore.status = "";
            TranscriptStore.clear-selection();
        }
    }

    VerticalLayout {
        spacing: AppStore.theme.metrics.spacing.none;

        PanelHeader {
            title: "Transcript";
        }

        // Action bar: transcribe / re-transcribe + status.
        VerticalLayout {
            padding: AppStore.theme.metrics.spacing.md;
            spacing: AppStore.theme.metrics.spacing.sm;

            if !TranscriptStore.available: CutlassText {
                text: "Transcription isn't available in this build. Rebuild with --features whisper to enable speech-to-text.";
                wrap: word-wrap;
                style: AppStore.theme.typography.caption;
                foreground: AppStore.theme.text.muted;
            }

            if TranscriptStore.available && !transcribable && TranscriptStore.word-count == 0: CutlassText {
                text: "Select a media clip with audio (at normal speed) to transcribe it.";
                wrap: word-wrap;
                style: AppStore.theme.typography.caption;
                foreground: AppStore.theme.text.muted;
            }

            if TranscriptStore.available && transcribable: HorizontalLayout {
                spacing: AppStore.theme.metrics.spacing.sm;
                alignment: start;

                if !TranscriptStore.running: AccentButton {
                    label: TranscriptStore.word-count == 0 ? "Transcribe" : "Re-transcribe";
                    clicked => {
                        TranscriptStore.clear-selection();
                        TranscriptStore.transcribe(selection.clip.id);
                    }
                }

                if TranscriptStore.running: CutlassText {
                    vertical-alignment: center;
                    text: "Transcribing…";
                    style: AppStore.theme.typography.caption;
                    foreground: AppStore.theme.text.muted;
                }
            }

            if TranscriptStore.status != "": CutlassText {
                text: TranscriptStore.status;
                wrap: word-wrap;
                style: AppStore.theme.typography.caption;
                foreground: AppStore.theme.text.secondary;
            }
        }

        // The transcript: lines of clickable word chips.
        CutlassScrollView {
            vertical-stretch: 1;
            viewport-width: self.width;
            viewport-height: body.preferred-height;
            show-horizontal-scrollbar: false;

            body := VerticalLayout {
                width: parent.width - 2 * AppStore.theme.metrics.spacing.md;
                x: AppStore.theme.metrics.spacing.md;
                alignment: start;
                spacing: AppStore.theme.metrics.spacing.xs;
                padding-bottom: AppStore.theme.metrics.spacing.md;

                if TranscriptStore.word-count == 0 && !TranscriptStore.running: CutlassText {
                    text: "Transcribe a clip, then select words and delete them to cut the video. The remaining speech closes up — one undoable step.";
                    wrap: word-wrap;
                    style: AppStore.theme.typography.caption;
                    foreground: AppStore.theme.text.muted;
                }

                for line in TranscriptStore.lines: HorizontalLayout {
                    alignment: start;
                    spacing: 2px;

                    for word in line.words: WordChip {
                        word: word;
                    }
                }
            }
        }

        // Delete footer: acts on the selected run of words.
        if TranscriptStore.has-selection(): VerticalLayout {
            padding: AppStore.theme.metrics.spacing.md;
            spacing: AppStore.theme.metrics.spacing.sm;

            HorizontalLayout {
                spacing: AppStore.theme.metrics.spacing.sm;
                alignment: start;

                AccentButton {
                    label: "Delete selection";
                    clicked => {
                        TranscriptStore.delete-selection(
                            min(TranscriptStore.sel-start, TranscriptStore.sel-end),
                            max(TranscriptStore.sel-start, TranscriptStore.sel-end),
                        );
                    }
                }

                SubtleButton {
                    label: "Clear";
                    clicked => {
                        TranscriptStore.clear-selection();
                    }
                }
            }

            CutlassText {
                text: "Deleting removes the words' span from the clip and ripples the rest closed.";
                wrap: word-wrap;
                style: AppStore.theme.typography.caption;
                foreground: AppStore.theme.text.muted;
            }
        }
    }
}
