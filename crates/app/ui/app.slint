// Cutlass launcher.
//
// Re-exports everything `editor.slint` exposes (EditorWindow, AppState,
// TimelineState, project DTOs) so the app crate's single
// `slint::include_modules!()` still surfaces the full UI API.

export * from "./editor.slint";

export component AppWindow inherits Window {
    title: "Cutlass";
    preferred-width: 720px;
    preferred-height: 480px;

    callback create-project();

    Rectangle {
        background: #121216;

        VerticalLayout {
            alignment: center;
            spacing: 28px;
            padding: 48px;

            VerticalLayout {
                alignment: center;
                spacing: 8px;

                Text {
                    text: "Cutlass";
                    color: #f5f5f7;
                    font-size: 56px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Text {
                    text: "AI-first prompt-to-edit video editing.";
                    color: #8c8c95;
                    font-size: 15px;
                    horizontal-alignment: center;
                }
            }

            HorizontalLayout {
                alignment: center;

                button := Rectangle {
                    width: 280px;
                    height: 64px;
                    border-radius: 14px;
                    background:
                        ta.pressed ? #3a4ce0
                        : ta.has-hover ? #5b6eff
                        : #4a5cff;
                    animate background { duration: 120ms; easing: ease-out; }

                    Text {
                        text: "Create Project";
                        color: white;
                        font-size: 18px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.create-project() }
                    }
                }
            }
        }
    }
}
