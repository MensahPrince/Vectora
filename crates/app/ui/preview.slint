// Minimal preview shell: image + playhead slider.

import { Slider, Button } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Cutlass Preview";
    preferred-width: 900px;
    preferred-height: 640px;

    in property <image> preview-image;
    // `in-out` + `<=>` on the slider: a one-way `value: root.playhead-seconds` pins the
    // thumb to the parent value; Rust never set `playhead-seconds`, so it stayed 0 and the
    // playhead UI never moved while scrubbing.
    in-out property <float> playhead-seconds: 0;
    in property <float> playhead-max: 10;
    in property <string> status-text: "Ready";

    callback scrub-requested(float);
    callback play-requested();
    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        Rectangle {
            vertical-stretch: 1;
            min-height: 400px;
            background: #141414;
            border-radius: 4px;
            clip: true;

            Image {
                width: 100%;
                height: 100%;
                source: root.preview-image;
                image-fit: ImageFit.contain;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        HorizontalLayout {
            spacing: 8px;

            Text {
                text: "Playhead";
                vertical-alignment: center;
            }

            Slider {
                minimum: 0;
                maximum: root.playhead-max;
                value <=> root.playhead-seconds;
                changed(value) => {
                    root.scrub-requested(value);
                }
            }

            Text {
                text: round(root.playhead-seconds) + "s / " + round(root.playhead-max) + "s";
                min-width: 100px;
                vertical-alignment: center;
            }

            Button {
                text: "Play";
                clicked => {
                    root.play-requested();
                }
            }
        }

        Text {
            text: root.status-text;
            color: #9a9a9a;
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}
