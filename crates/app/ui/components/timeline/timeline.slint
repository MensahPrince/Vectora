// Bottom timeline region (height comes from parent `timeline-height`).
//
// Layout:
//   ┌─────────────────────────┬─────────────────────────────────────────┐
//   │ Toolbar                                                          │
//   ├─────────────────────────┬─────────────────────────────────────────┤
//   │   (top spacer)          │ Ruler                                   │
//   ├─────────────────────────┼─────────────────────────────────────────┤
//   │ track-header column     │ tracks (Flickable; ClipView pills)      │
//   │  (TrackHeader rows,     │  (TrackRow rows, each w/ ClipViews)     │
//   │   vertically scrolled)  │                                         │
//   └─────────────────────────┴─────────────────────────────────────────┘
//
// Both columns iterate the same `AppState.project.sequence.tracks` model
// with `spacing: 10px`, so row N on the left lines up with row N on the
// right by construction.

import { Ruler } from "./ruler.slint";
import { TimelineState } from "./state.slint";
import { Toolbar } from "./toolbar.slint";
import { PlayHead } from "./playhead.slint";
import { TrackRow, TrackHeader } from "./track.slint";
import { HorizontalDivider, VerticalDivider } from "../divider.slint";
import { AppState } from "../../models/app_state.slint";

export component TimelinePanel inherits Rectangle {
    horizontal-stretch: 1;
    background: #28282a;

    // Spacing between adjacent track rows. Kept in one place so the left
    // header column and the right content column stay vertically aligned.
    property <length> row-gap: 10px;

    // Mirror of the global playhead so we can hang a `changed` handler off
    // it — Slint `changed` handlers must live on a local property, not on a
    // global one. Each time the user drags the playhead or clicks the ruler
    // this fires `AppState.request-preview` with the time in seconds, which
    // Rust forwards to `engine::Engine::seek_scrub` (a non-blocking,
    // latest-wins slot so we can spam this on every pointer move).
    property <length> playhead-tracker: TimelineState.playhead-x;
    changed playhead-tracker => {
        AppState.request-preview(playhead-tracker / TimelineState.zoom / 1px);
    }

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;

        Toolbar { }

        HorizontalDivider { }

        HorizontalLayout {
            spacing: 12px;

            // ── Left: track headers ──────────────────────────────────────
            VerticalLayout {
                horizontal-stretch: 0;
                width: 200px;

                // Top spacer aligns the first header with the first track
                // row (skipping the ruler's vertical band).
                Rectangle {
                    height: TimelineState.ruler-height;
                }

                track-headers := Flickable {
                    vertical-stretch: 1;
                    horizontal-stretch: 0;
                    interactive: false;
                    // Mirror vertical scroll from the content column so
                    // headers stay locked to their rows.
                    viewport-y: -TimelineState.scroll-y;

                    VerticalLayout {
                        spacing: row-gap;
                        for track in AppState.project.sequence.tracks: TrackHeader {
                            info: track;
                        }
                    }
                }
            }

            VerticalDivider { }
            // ── Right: ruler + scrollable track content ─────────────────
            Rectangle {
                // clip: true; // TODO: uncomment this
                horizontal-stretch: 1;
                height: 100%;

                VerticalLayout {
                    width: 100%;
                    height: 100%;

                    Ruler {
                        height: TimelineState.ruler-height;
                    }

                    tracks := Flickable {
                        vertical-stretch: 1;
                        horizontal-stretch: 1;

                        // Horizontal scroll extent comes from the active
                        // sequence's duration × zoom (clamped so it always
                        // fills the visible panel width — see
                        // `TimelineState.viewport-width`). Vertical extent
                        // comes from the natural height of the VerticalLayout
                        // below.
                        viewport-width: TimelineState.viewport-width;

                        interactive: false;
                        // The Flickable's `viewport-x` is <= 0 when scrolled
                        // right; the rest of the UI reasons about scroll as
                        // a positive value, so we negate.
                        changed viewport-x => {
                            TimelineState.scroll-x = -self.viewport-x;
                        }
                        changed viewport-y => {
                            TimelineState.scroll-y = -self.viewport-y;
                        }
                        // Feed the panel's actual width back to TimelineState
                        // so `viewport-width` (and therefore TrackRow widths)
                        // stays at least as wide as the screen. `init` handles
                        // the first frame; `changed` keeps us right-sized on
                        // window resize / split-pane drag.
                        init => {
                            TimelineState.available-width = self.width;
                        }
                        changed width => {
                            TimelineState.available-width = self.width;
                        }

                        VerticalLayout {
                            spacing: row-gap;
                            for track in AppState.project.sequence.tracks: TrackRow {
                                info: track;
                            }
                        }
                    }
                }

                PlayHead {
                    y: 0;
                    height: parent.height;
                    x: TimelineState.playhead-x - TimelineState.scroll-x;
                }
            }
        }
    }
}
