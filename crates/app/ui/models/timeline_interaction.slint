// Ephemeral timeline editing state and callbacks wired from Rust.
//
// Selection is not part of the domain `Project`; Rust holds the active
// clip id and re-applies `Clip.selected` when rebuilding the DTO.
// Clip moves commit through `move-clip` on pointer-up (Slint previews
// the drag via `drag-preview-start-sec`; Rust runs `timeline::MoveClip` once).

export global TimelineInteraction {
    in-out property <string> selected-clip-id: "";

    // Active clip drag (full-window grab in the editor shell).
    in-out property <bool> clip-drag-active: false;
    in-out property <string> dragging-clip-id: "";
    in-out property <float> drag-start-sec: 0;
    in-out property <length> drag-origin-root-x: 0;
    in-out property <float> drag-preview-start-sec: 0;

    // Empty `clip-id` clears selection. Rust refreshes the project DTO.
    callback select-clip(string /* clip-id */);

    // Commit a clip move. `new-start-sec` is timeline time in seconds.
    callback move-clip(string /* clip-id */, float /* new-start-sec */);
}
