import { Project } from "./project.slint";

export global AppState {
    in-out property <Project> project;

    // Latest decoded preview frame, pushed from the engine worker through
    // `slint::invoke_from_event_loop`. Bound by `PreviewPanel`.
    in-out property <image> preview-frame;

    // Fired from the timeline whenever the playhead moves. Payload is the
    // timeline time in **seconds** (float). Rust connects this to
    // `engine::Engine::seek_scrub`.
    callback request-preview(float);

    // Fired from the library pane's `+` button or empty-state region. Rust
    // opens a native file picker, probes each picked path via
    // `engine::probe`, and appends the resulting `MediaSource`s to
    // `project.media-bin`.
    callback import-media();
}
